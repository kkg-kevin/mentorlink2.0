<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mentor Profile | MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #003049;
      --secondary-color: #0077b6;
      --accent-color: #2a9d8f;
      --surface-border: #d8e8f0;
      --muted-text: #61727c;
    }

    body {
      font-family: 'Poppins', sans-serif;
      color: var(--primary-color);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        #fbfeff;
      min-height: 100vh;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      padding-bottom: 36px;
    }

    .page-shell .container {
      max-width: min(1560px, calc(100vw - 36px));
    }

    .navbar {
      margin: 18px auto 0;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 14px 34px rgba(0, 48, 73, 0.08);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--primary-color) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: rgba(0, 119, 182, 0.08);
    }

    .btn-logout,
    .btn-save {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-save {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-logout:hover,
    .btn-save:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      overflow: hidden;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 760px;
      line-height: 1.8;
      margin: 0;
    }

    .profile-card {
      margin-top: 26px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(216, 232, 240, 0.95);
      border-radius: 28px;
      box-shadow: 0 18px 40px rgba(0, 48, 73, 0.08);
      overflow: hidden;
    }

    .profile-grid {
      display: grid;
      grid-template-columns: 320px minmax(0, 1fr);
      gap: 0;
    }

    .profile-sidebar {
      padding: 34px 28px;
      background: linear-gradient(180deg, rgba(246, 251, 253, 0.96), rgba(255, 255, 255, 0.94));
      border-right: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
    }

    .avatar-frame {
      width: 148px;
      height: 148px;
      border-radius: 34px;
      padding: 10px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.14), rgba(42, 157, 143, 0.14));
      box-shadow: 0 16px 32px rgba(0, 48, 73, 0.10);
    }

    .avatar-upload {
      display: block;
      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .avatar-upload:hover {
      transform: translateY(-2px);
    }

    .profile-avatar {
      width: 100%;
      height: 100%;
      border-radius: 26px;
      background: #fff;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 3rem;
      color: #6f96ab;
      overflow: hidden;
    }

    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      transform: scale(1.12);
    }

    .avatar-upload-note {
      margin-top: 10px;
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .visually-hidden-file-input {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .profile-name {
      font-weight: 700;
      font-size: 1.4rem;
      margin-bottom: 6px;
    }

    .profile-email {
      color: var(--muted-text);
      margin-bottom: 18px;
      word-break: break-word;
    }

    .info-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 16px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .rating-summary {
      margin-top: 18px;
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(255, 193, 7, 0.15), rgba(255, 255, 255, 0.96));
      border: 1px solid rgba(255, 193, 7, 0.28);
    }

    .rating-summary-value {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-weight: 700;
      font-size: 1.15rem;
      margin-bottom: 4px;
    }

    .rating-summary-value i {
      color: #f4b400;
    }

    .rating-summary-meta {
      color: var(--muted-text);
      margin: 0;
      font-size: 0.92rem;
    }

    .sidebar-note {
      margin-top: 20px;
      color: var(--muted-text);
      line-height: 1.7;
      font-size: 0.94rem;
    }

    .form-panel {
      padding: 34px 34px 30px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .form-panel h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .form-panel .section-subtitle {
      color: var(--muted-text);
      line-height: 1.7;
      margin-bottom: 28px;
      text-align: left;
      font-size: 1rem;
    }

    .form-label {
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 8px;
    }

    .form-control,
    .form-select {
      border-radius: 18px;
      border: 1px solid var(--surface-border);
      padding: 13px 16px;
      background: #fbfeff;
      transition: all 0.25s ease;
    }

    .form-control:focus,
    .form-select:focus {
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      outline: none;
      background-color: #fff;
      border-color: rgba(0, 119, 182, 0.45);
    }

    textarea.form-control {
      min-height: 120px;
    }

    .field-group {
      margin-bottom: 20px;
    }

    .review-panel {
      margin-bottom: 28px;
      padding: 22px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(246, 251, 253, 0.94), rgba(255, 255, 255, 0.98));
      border: 1px solid rgba(216, 232, 240, 0.95);
    }

    .review-panel h4 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .review-panel p {
      color: var(--muted-text);
      margin-bottom: 0;
      line-height: 1.7;
    }

    .review-list {
      margin-top: 18px;
      display: grid;
      gap: 14px;
    }

    .review-item {
      padding: 16px 18px;
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(216, 232, 240, 0.95);
    }

    .review-item-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 10px;
    }

    .review-author {
      font-weight: 600;
    }

    .review-date {
      color: var(--muted-text);
      font-size: 0.85rem;
    }

    .review-rating {
      color: #f4b400;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .review-empty {
      margin-top: 18px;
      padding: 18px;
      border-radius: 18px;
      background: #fff;
      border: 1px dashed rgba(216, 232, 240, 0.95);
      text-align: center;
      color: var(--muted-text);
    }

    footer {
      background: rgba(255, 255, 255, 0.88);
      border-top: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--muted-text);
      margin-top: 42px;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.3rem;
      }

      .profile-grid {
        grid-template-columns: 1fr;
      }

      .profile-sidebar {
        border-right: none;
        border-bottom: 1px solid rgba(216, 232, 240, 0.95);
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 18px);
      }

      .navbar {
        border-radius: 18px;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .form-panel,
      .profile-sidebar {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentor/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentor/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/mentor/analytics" class="nav-link">Analytics</a></li>
            <li class="nav-item"><a href="/mentor/profile" class="nav-link active">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-person-badge-fill"></i>
          Mentor Profile
        </div>
        <h1>Present the experience and availability that make your <span>mentorship valuable.</span></h1>
        <p>Keep your profile updated so mentees can understand your expertise, background, and the kind of guidance you can offer before they request a session.</p>
      </div>
    </section>

    <section class="container">
      <div class="profile-card">
        <form method="POST" action="/mentor/profile/update" enctype="multipart/form-data">
          <div class="profile-grid">
          <aside class="profile-sidebar">
            <label for="profilePictureInput" class="avatar-frame avatar-upload" aria-label="Choose profile picture">
              <div class="profile-avatar">
                {{#if user.profilePicture}}
                  <img src="{{user.profilePicture}}" alt="{{user.name}}" id="profilePicturePreview">
                {{else}}
                  <i class="bi bi-person" id="profilePicturePlaceholder"></i>
                  <img src="" alt="{{user.name}}" id="profilePicturePreview" style="display: none;">
                {{/if}}
              </div>
            </label>
            <input id="profilePictureInput" type="file" name="profilePicture" class="visually-hidden-file-input" accept="image/*">
            <div class="avatar-upload-note">Click the photo area to upload</div>
            <div class="profile-name">{{user.name}}</div>
            <div class="profile-email">{{user.email}}</div>
            <div class="info-chip"><i class="bi bi-lightbulb-fill"></i> Mentor Account</div>
            <div class="rating-summary">
              {{#if mentorRating.ratingCount}}
                <div class="rating-summary-value">
                  <i class="bi bi-star-fill"></i>
                  <span>{{mentorRating.avgRating}} / 5</span>
                </div>
                <p class="rating-summary-meta">{{mentorRating.ratingCount}} total reviews from mentees</p>
              {{else}}
                <div class="rating-summary-value">
                  <i class="bi bi-star"></i>
                  <span>No ratings yet</span>
                </div>
                <p class="rating-summary-meta">Your mentee feedback will appear here after completed sessions are reviewed.</p>
              {{/if}}
            </div>
            <p class="sidebar-note">A clear mentor profile helps the right mentees understand your strengths and feel confident reaching out.</p>
          </aside>

          <div class="form-panel">
            <div class="section-kicker"><i class="bi bi-pencil-square"></i> Update Details</div>
            <h3>Mentor information</h3>
            <p class="section-subtitle">Refine your professional details and biography without changing the existing profile flow.</p>
            <div class="review-panel">
              <h4>Recent mentee feedback</h4>
              <p>These are the latest comments and ratings submitted after completed sessions.</p>
              {{#if hasRecentReviews}}
                <div class="review-list">
                  {{#each recentReviews}}
                    <div class="review-item">
                      <div class="review-item-header">
                        <div class="review-author">{{#if from}}{{from.name}}{{else}}Mentee{{/if}}</div>
                        <div class="review-date">{{formatDate createdAt}}</div>
                      </div>
                      <div class="review-rating">{{rating}} / 5</div>
                      <div>{{comment}}</div>
                    </div>
                  {{/each}}
                </div>
              {{else}}
                <div class="review-empty">
                  No reviews yet. Once mentees submit feedback after completed sessions, their comments will show here.
                </div>
              {{/if}}
            </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Full name</label>
                  <input type="text" class="form-control" value="{{user.name}}" disabled>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Email Account</label>
                  <input type="email" class="form-control" value="{{user.email}}" disabled>
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phone" class="form-control" value="{{mentor.phone}}" placeholder="e.g +2547....">
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Profession / Industry</label>
                  <input type="text" name="industry" class="form-control" value="{{mentor.industry}}" placeholder="e.g. Software Engineer, Education">
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Years of experience</label>
                  <input type="number" name="experienceYears" class="form-control" value="{{mentor.experienceYears}}" placeholder="e.g. 5">
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Specialization</label>
                <input type="text" name="specialization" class="form-control" value="{{mentor.specialization}}" placeholder="e.g. Leadership, Programming, AI...">
              </div>

              <div class="field-group">
                <label class="form-label">Availability</label>
                <select name="availability" class="form-select">
                  <option value="" selected disabled>Select availability</option>
                  <option value="Weekdays" {{#ifEq mentor.availability "Weekdays"}}selected{{/ifEq}}>Weekdays</option>
                  <option value="Weekends" {{#ifEq mentor.availability "Weekends"}}selected{{/ifEq}}>Weekends</option>
                  <option value="Evenings" {{#ifEq mentor.availability "Evenings"}}selected{{/ifEq}}>Evenings</option>
                </select>
              </div>

              <div class="field-group">
                <label class="form-label">Bio / Description</label>
                <textarea name="bio" class="form-control" placeholder="Write a short bio...">{{mentor.bio}}</textarea>
              </div>

              <button type="submit" class="btn btn-save px-4 py-3">Save Profile</button>
          </div>
          </div>
        </form>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const mentorProfileInput = document.getElementById('profilePictureInput');
    const mentorProfilePreview = document.getElementById('profilePicturePreview');
    const mentorProfilePlaceholder = document.getElementById('profilePicturePlaceholder');

    if (mentorProfileInput && mentorProfilePreview) {
      mentorProfileInput.addEventListener('change', (event) => {
        const [file] = event.target.files;

        if (!file) {
          return;
        }

        mentorProfilePreview.src = URL.createObjectURL(file);
        mentorProfilePreview.style.display = 'block';

        if (mentorProfilePlaceholder) {
          mentorProfilePlaceholder.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
