<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mentor Feedback - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1580px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout,
    .btn-submit,
    .btn-back {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-submit {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-back {
      color: var(--secondary-color);
      border: 1px solid var(--secondary-color);
      background: transparent;
    }

    .btn-logout:hover,
    .btn-submit:hover,
    .btn-back:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background: var(--bg-hero);
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 860px;
      line-height: 1.8;
      margin: 0;
    }

    .feedback-section {
      margin-top: 24px;
    }

    .feedback-card {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      box-shadow: var(--card-shadow);
      padding: 28px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-chip);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .session-summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 20px 0 18px;
    }

    .summary-item {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 12px 14px;
    }

    .summary-label {
      color: var(--text-muted);
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 6px;
    }

    .summary-value {
      font-weight: 600;
    }

    .form-label {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .form-control {
      border-radius: 18px;
      border: 1px solid var(--border-input);
      padding: 13px 16px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-control:focus {
      border-color: rgba(0, 119, 182, 0.45);
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      background: var(--bg-surface);
    }

    .helper-text {
      color: var(--text-muted);
      font-size: 0.88rem;
      line-height: 1.6;
    }

    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 18px;
      flex-wrap: wrap;
    }

    .feedback-alert {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 14px;
      color: var(--text-muted);
      margin-top: 18px;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: auto;
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentor/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentor/sessions" class="nav-link active">Sessions</a></li>
            <li class="nav-item"><a href="/mentor/analytics" class="nav-link">Analytics</a></li>
            <li class="nav-item"><a href="/mentor/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-chat-square-text-fill"></i>
          Mentor Feedback
        </div>
        <h1>Share session feedback with <span>{{#if session.mentee.user}}{{session.mentee.user.name}}{{else}}your mentee{{/if}}.</span></h1>
        <p>Provide focused guidance and next steps after a completed session. Your feedback will be visible only to the mentee for this session.</p>
      </div>
    </section>

    <section class="container feedback-section">
      <div class="feedback-card">
        <div class="section-kicker"><i class="bi bi-clipboard-check"></i> Session Summary</div>
        <div class="session-summary">
          <div class="summary-item">
            <div class="summary-label">Mentee</div>
            <div class="summary-value">{{#if session.mentee.user}}{{session.mentee.user.name}}{{else}}Mentee{{/if}}</div>
          </div>
          <div class="summary-item">
            <div class="summary-label">Session Date</div>
            <div class="summary-value">{{formatDate session.scheduledAt}}</div>
          </div>
          <div class="summary-item">
            <div class="summary-label">Session Time</div>
            <div class="summary-value">{{formatTime session.scheduledAt}}</div>
          </div>
        </div>

        {{#if hasFeedback}}
          <div class="feedback-alert">
            Feedback has already been sent for this session.
          </div>
          <div class="form-actions">
            <a href="/mentor/sessions" class="btn btn-back">Back to Sessions</a>
          </div>
        {{else}}
          <form method="POST" action="/mentor/feedback/submit">
            <input type="hidden" name="sessionId" value="{{session._id}}">
            <div class="mb-3">
              <label for="mentorComment" class="form-label">Feedback Notes</label>
              <textarea class="form-control" id="mentorComment" name="comment" rows="6" required placeholder="Share strengths, progress, and next steps for the mentee."></textarea>
              <div class="helper-text mt-2">Keep it clear and actionable. This feedback is visible to the mentee only and mentees cannot reply.</div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-submit">Send Feedback</button>
              <a href="/mentor/sessions" class="btn btn-back">Cancel</a>
            </div>
          </form>
        {{/if}}
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
