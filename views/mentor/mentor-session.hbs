<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MentorLink | Mentor Sessions</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1600px, calc(100vw - 36px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-logout:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 760px;
      line-height: 1.8;
      margin: 0;
    }

    .stats-section,
    .sessions-section {
      margin-top: 24px;
    }

    .stat-card,
    .sessions-card,
    .session-item,
    .empty-state {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 26px;
      box-shadow: var(--card-shadow);
    }

    .stat-card {
      padding: 26px 22px;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--secondary-color), var(--accent-color));
    }

    .stat-top {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 16px;
    }

    .stat-label {
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: 8px;
    }

    .stat-card h4 {
      font-weight: 700;
      font-size: 2.2rem;
      margin-bottom: 8px;
    }

    .stat-icon {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.55rem;
      color: #fff;
      box-shadow: 0 14px 28px rgba(0, 48, 73, 0.10);
    }

    .stat-icon.blue {
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
    }

    .stat-icon.green {
      background: linear-gradient(135deg, var(--accent-color), #1f877b);
    }

    .sessions-card {
      padding: 28px;
    }

    .section-top {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 16px;
      margin-bottom: 20px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .section-top h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .section-top p {
      color: var(--text-muted);
      margin: 0;
    }

    .session-item {
      padding: 20px;
      margin-bottom: 14px;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .session-item:last-child {
      margin-bottom: 0;
    }

    .session-item:hover {
      transform: translateY(-4px);
      box-shadow: 0 22px 40px rgba(0, 48, 73, 0.10);
      border-color: #bfdbe9;
    }

    .session-item-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 12px;
      margin-bottom: 12px;
    }

    .session-item-name {
      font-weight: 700;
      color: var(--text-primary);
    }

    .session-item-details {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .detail-chip,
    .session-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      font-weight: 600;
    }

    .detail-chip {
      background: var(--bg-chip);
      color: var(--text-primary);
    }

    .session-status {
      font-size: 0.78rem;
    }

    .status-pending {
      background: rgba(255, 193, 7, 0.16);
      color: #8a6a00;
    }

    .status-confirmed,
    .status-accepted {
      background: rgba(0, 119, 182, 0.10);
      color: #0c5a7a;
    }

    .status-completed {
      background: rgba(42, 157, 143, 0.14);
      color: #17675e;
    }

    .feedback-action {
      margin-top: 10px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .feedback-badge {
      background: rgba(42, 157, 143, 0.14);
      color: #17675e;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.8rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .empty-state {
      padding: 36px 24px;
      text-align: center;
    }

    .empty-state i {
      font-size: 2.4rem;
      color: var(--secondary-color);
      margin-bottom: 14px;
      display: inline-block;
    }

    .empty-state h5 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .empty-state p {
      color: var(--text-muted);
      margin: 0;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: auto;
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 18px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .sessions-card {
        padding: 20px;
      }

      .section-top,
      .session-item-header,
      .session-item-details {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/mentor/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="menu">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentor/sessions" class="nav-link active">Sessions</a></li>
            <li class="nav-item"><a href="/messages" class="nav-link">Messages</a></li>
            <li class="nav-item"><a href="/mentor/analytics" class="nav-link">Analytics</a></li>
            <li class="nav-item"><a href="/mentor/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-calendar2-week-fill"></i>
          Session Management
        </div>
        <h1>Track accepted sessions and completed mentorship <span>at a glance.</span></h1>
        <p>This page gives you a cleaner view of all mentorship activity while keeping the same status flow and completion actions already working in the system.</p>
      </div>
    </section>

    <section class="container stats-section">
      <div class="row g-4">
        <div class="col-md-6">
          <div class="stat-card">
            <div class="stat-top">
              <div>
                <div class="stat-label">Active Mentees</div>
                <h4>{{#if stats}}{{stats.activeMentees}}{{else}}3{{/if}}</h4>
                <p class="mb-0 text-muted">Unique mentees currently engaging with you.</p>
              </div>
              <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="stat-card">
            <div class="stat-top">
              <div>
                <div class="stat-label">Sessions Completed</div>
                <h4>{{#if stats}}{{stats.completedSessions}}{{else}}8{{/if}}</h4>
                <p class="mb-0 text-muted">Sessions already finished and ready for reflection.</p>
              </div>
              <div class="stat-icon green"><i class="bi bi-graph-up-arrow"></i></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container sessions-section">
      <div class="sessions-card">
        <div class="section-top">
          <div>
            <div class="section-kicker"><i class="bi bi-list-check"></i> Session Log</div>
            <h3>All Sessions</h3>
            <p>Review every mentorship session by mentee, date, time, and status, and mark accepted sessions as completed when you’re done.</p>
          </div>
        </div>

        {{#if sessions}}
          {{#each sessions}}
          <div class="session-item">
            <div class="session-item-header">
              <span class="session-item-name">{{#if this.mentee.user}}{{this.mentee.user.name}}{{else}}Mentee{{/if}}</span>
              <span class="session-status status-{{this.status}}">{{this.status}}</span>
            </div>
            <div class="session-item-details">
              <span class="detail-chip"><i class="bi bi-calendar-event"></i> {{formatDate this.scheduledAt}}</span>
              <span class="detail-chip"><i class="bi bi-clock"></i> {{formatTime this.scheduledAt}}</span>
              {{#if this.mentee.educationLevel}}
                <span class="detail-chip"><i class="bi bi-mortarboard"></i> {{this.mentee.educationLevel}}</span>
              {{/if}}
              {{#if this.mentee.location}}
                <span class="detail-chip"><i class="bi bi-geo-alt"></i> {{this.mentee.location}}</span>
              {{/if}}
              {{#if this.mentee.currentRole}}
                <span class="detail-chip"><i class="bi bi-briefcase"></i> {{this.mentee.currentRole}}</span>
              {{/if}}
            </div>
            {{#if this.mentee.goals}}
              <div class="session-goals" style="background: rgba(0,119,182,0.04); padding: 12px; border-radius: 12px; margin: 8px 0; font-size: 0.9rem; color: var(--muted-text);">
                <strong style="color: var(--primary-color);">Goals:</strong> {{this.mentee.goals}}
              </div>
            {{/if}}
            {{#if this.mentee.skills}}
              <div class="session-skills" style="margin-top: 8px;">
                <strong style="font-size: 0.85rem; color: var(--muted-text);">Skills:</strong>
                {{#each this.mentee.skills}}
                  <span class="badge" style="background: rgba(0,119,182,0.1); color: var(--secondary-color); margin-left: 6px; font-size: 0.75rem;">{{this}}</span>
                {{/each}}
              </div>
            {{/if}}
            {{#if this.mentee.communicationPreference}}
              <div class="session-preferences" style="margin-top: 8px; font-size: 0.8rem; color: var(--muted-text);">
                <i class="bi bi-chat-dots"></i> Prefers: {{this.mentee.communicationPreference}} communication
                {{#if this.mentee.sessionFrequency}}
                  | <i class="bi bi-calendar-check"></i> {{this.mentee.sessionFrequency}} sessions
                {{/if}}
              </div>
            {{/if}}
            {{#ifEq this.status "accepted"}}
            <form method="POST" action="/mentor/session/{{this._id}}/complete" style="display:inline-block; margin-top:10px;">
              <button type="submit" class="btn btn-sm btn-success" style="border-radius:999px;">Mark as Completed</button>
            </form>
            {{/ifEq}}
            {{#ifEq this.status "completed"}}
            <div class="feedback-action">
              {{#if this.hasMentorFeedback}}
                <span class="feedback-badge"><i class="bi bi-check-circle"></i> Feedback sent</span>
              {{else}}
                <a href="/mentor/feedback/{{this._id}}" class="btn btn-sm btn-outline-primary" style="border-radius:999px;">Leave Feedback</a>
              {{/if}}
            </div>
            {{/ifEq}}
          </div>
          {{/each}}
        {{else}}
          <div class="empty-state">
            <i class="bi bi-calendar2-x"></i>
            <h5>No sessions yet</h5>
            <p>Your accepted and completed mentorship sessions will appear here as your activity grows.</p>
          </div>
        {{/if}}
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
