<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MentorLink Analytics</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1580px, calc(100vw - 36px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-logout:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 760px;
      line-height: 1.8;
      margin: 0;
    }

    .stats-section,
    .chart-section {
      margin-top: 24px;
    }

    .stat-card,
    .chart-card {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      box-shadow: var(--card-shadow);
    }

    .stat-card {
      padding: 26px 22px;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--secondary-color), var(--accent-color));
    }

    .stat-top {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 16px;
    }

    .stat-label {
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: 8px;
    }

    .stat-card h4 {
      font-weight: 700;
      font-size: 2.2rem;
      margin-bottom: 8px;
    }

    .stat-icon {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.55rem;
      color: #fff;
      box-shadow: 0 14px 28px rgba(0, 48, 73, 0.10);
    }

    .stat-icon.green {
      background: linear-gradient(135deg, var(--accent-color), #1f877b);
    }

    .stat-icon.yellow {
      background: linear-gradient(135deg, #d9b240, #c89200);
    }

    .stat-icon.blue {
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
    }

    .chart-card {
      padding: 28px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .chart-card h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .chart-card p {
      color: var(--text-muted);
      margin-bottom: 22px;
      line-height: 1.7;
    }

    .trend-card {
      position: relative;
    }

    .trend-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .trend-title h3 {
      margin-bottom: 6px;
    }

    .trend-title p {
      margin-bottom: 12px;
    }

    .trend-tags {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .trend-stats {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .trend-stat {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 10px 14px;
      min-width: 140px;
    }

    .trend-stat-label {
      color: var(--text-muted);
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }

    .trend-stat-value {
      font-size: 1.4rem;
      font-weight: 700;
    }

    .trend-stat-meta {
      color: var(--text-muted);
      font-size: 0.78rem;
      margin-top: 4px;
    }

    .trend-legend {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      color: var(--text-muted);
      font-size: 0.85rem;
      margin-bottom: 12px;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .dot-mentees { background: #2a9d8f; }
    .dot-sessions { background: #d9b240; }
    .dot-rating { background: #0077b6; }

    .chart-shell {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 22px;
      padding: 18px;
      box-shadow: inset 0 0 0 1px rgba(0, 48, 73, 0.02);
    }

    .chart-canvas {
      height: 320px;
    }

    .controls-section,
    .kpi-section,
    .insights-section {
      margin-top: 24px;
    }

    .controls-card {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 22px;
      padding: 18px 22px;
      box-shadow: var(--card-shadow);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .controls-group {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .controls-label {
      font-weight: 600;
      color: var(--text-muted);
      font-size: 0.92rem;
    }

    .controls-select {
      min-width: 180px;
      border-radius: 14px;
    }

    .compare-switch {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn-apply {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      padding: 8px 18px;
    }

    .controls-meta {
      margin-top: 12px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .range-pill {
      background: var(--bg-chip);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.82rem;
      font-weight: 600;
    }

    .kpi-card {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      padding: 22px;
      box-shadow: var(--card-shadow);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .kpi-header {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }

    .kpi-label {
      color: var(--text-muted);
      font-weight: 600;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 2.1rem;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .kpi-meta {
      color: var(--muted-text);
      font-size: 0.88rem;
    }

    .kpi-icon {
      width: 54px;
      height: 54px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      color: #fff;
      box-shadow: 0 12px 24px rgba(0, 48, 73, 0.14);
    }

    .kpi-icon.green { background: linear-gradient(135deg, #2a9d8f, #1f877b); }
    .kpi-icon.yellow { background: linear-gradient(135deg, #d9b240, #c89200); }
    .kpi-icon.blue { background: linear-gradient(135deg, var(--secondary-color), #005f89); }
    .kpi-icon.purple { background: linear-gradient(135deg, #4b9cff, #2b6fd6); }

    .kpi-trend {
      margin-top: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.9rem;
      font-weight: 600;
    }

    .kpi-trend .trend-label {
      color: var(--text-muted);
      font-weight: 500;
    }

    .trend-up { color: #1f877b; }
    .trend-down { color: #c23c2a; }
    .trend-neutral { color: var(--text-muted); }

    .rating-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .rating-label {
      min-width: 56px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .rating-bar {
      flex: 1;
      height: 10px;
      border-radius: 999px;
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      overflow: hidden;
    }

    .rating-fill {
      height: 100%;
      background: linear-gradient(135deg, var(--secondary-color), var(--accent-color));
    }

    .rating-meta {
      min-width: 90px;
      text-align: right;
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    .response-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }

    .response-score {
      font-size: 2.3rem;
      font-weight: 700;
    }

    .response-meta {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .response-status {
      border-radius: 14px;
      padding: 10px 14px;
      font-weight: 600;
      font-size: 0.85rem;
    }

    .response-bar {
      margin-top: 16px;
      height: 10px;
      border-radius: 999px;
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      overflow: hidden;
    }

    .response-fill {
      height: 100%;
    }

    .status-good {
      background: rgba(42, 157, 143, 0.15);
      color: #1f877b;
    }

    .status-warn {
      background: rgba(217, 178, 64, 0.18);
      color: #c89200;
    }

    .status-bad {
      background: rgba(220, 53, 69, 0.15);
      color: #b02a37;
    }

    .status-good.response-fill {
      background: linear-gradient(135deg, #2a9d8f, #1f877b);
    }

    .status-warn.response-fill {
      background: linear-gradient(135deg, #d9b240, #c89200);
    }

    .status-bad.response-fill {
      background: linear-gradient(135deg, #dc3545, #b02a37);
    }

    .funnel-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .funnel-step {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 18px;
      padding: 16px;
    }

    .funnel-label {
      color: var(--text-muted);
      font-size: 0.88rem;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .funnel-count {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .funnel-rate {
      margin-top: 8px;
      color: var(--text-muted);
      font-size: 0.82rem;
    }

    .theme-block {
      margin-bottom: 18px;
    }

    .theme-title {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .theme-list {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .theme-chip {
      background: var(--bg-chip);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.82rem;
      font-weight: 600;
    }

    .theme-chip.empty {
      background: var(--bg-surface-soft);
      color: var(--text-muted);
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: auto;
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 18px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .chart-card {
        padding: 20px;
      }

      .trend-top {
        align-items: flex-start;
      }

      .trend-stats {
        justify-content: flex-start;
      }

      .chart-shell {
        padding: 14px;
      }

      .chart-canvas {
        height: 260px;
      }

      .controls-card {
        align-items: flex-start;
      }

      .funnel-list {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentor/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentor/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/messages" class="nav-link">Messages</a></li>
            <li class="nav-item"><a href="/mentor/analytics" class="nav-link active">Analytics</a></li>
            <li class="nav-item"><a href="/mentor/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-bar-chart-fill"></i>
          Mentor Analytics
        </div>
        <h1>Understand the reach and quality of your <span>mentorship impact.</span></h1>
        <p>These metrics help you quickly see how many mentees you’re supporting, how active your sessions are, and how your guidance is being rated over time.</p>
      </div>
    </section>

    <section class="container controls-section">
      <form class="controls-card" method="GET" action="/mentor/analytics">
        <div class="controls-group">
          <div class="controls-label">Time range</div>
          <select class="form-select controls-select" name="range">
            <option value="7" {{#ifEq rangeDays 7}}selected{{/ifEq}}>Last 7 days</option>
            <option value="30" {{#ifEq rangeDays 30}}selected{{/ifEq}}>Last 30 days</option>
            <option value="90" {{#ifEq rangeDays 90}}selected{{/ifEq}}>Last 90 days</option>
          </select>
        </div>
        <div class="form-check form-switch compare-switch">
          <input class="form-check-input" type="checkbox" id="compareToggle" name="compare" value="1" {{#if compareEnabled}}checked{{/if}}>
          <label class="form-check-label" for="compareToggle">Compare to previous period</label>
        </div>
        <button type="submit" class="btn btn-apply">Apply</button>
      </form>
      <div class="controls-meta">
        <span class="range-pill">{{rangeLabel}}</span>
        {{#if compareEnabled}}
          <span class="range-pill">Compared to {{compareLabel}}</span>
        {{/if}}
      </div>
    </section>

    <section class="container kpi-section">
      <div class="row g-4">
        {{#each kpis}}
        <div class="col-md-6 col-xl-3">
          <div class="kpi-card">
            <div class="kpi-header">
              <div>
                <div class="kpi-label">{{this.label}}</div>
                <div class="kpi-value">{{this.value}}</div>
                <div class="kpi-meta">{{this.meta}}</div>
              </div>
              <div class="kpi-icon {{this.iconClass}}"><i class="bi {{this.icon}}"></i></div>
            </div>
            <div class="kpi-trend {{this.trendClass}}">
              <i class="bi {{this.trendIcon}}"></i>
              <span class="trend-value">{{this.trendValue}}</span>
              <span class="trend-label">{{this.trendLabel}}</span>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </section>

    <section class="container insights-section">
      <div class="row g-4">
        <div class="col-lg-6">
          <div class="chart-card">
            <div class="section-kicker"><i class="bi bi-star-fill"></i> Ratings Distribution</div>
            <h3>Rating breakdown</h3>
            <p>Counts and shares across the feedback you received in this range.</p>
            <div class="rating-list">
              {{#each ratingsBreakdown}}
              <div class="rating-row" title="{{this.count}} feedback ({{this.percent}}%)">
                <div class="rating-label">{{this.stars}} <i class="bi bi-star-fill"></i></div>
                <div class="rating-bar">
                  <div class="rating-fill" style="width: {{this.percent}}%;"></div>
                </div>
                <div class="rating-meta">{{this.count}} | {{this.percent}}%</div>
              </div>
              {{/each}}
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="chart-card">
            <div class="section-kicker"><i class="bi bi-chat-square-heart"></i> Feedback Response Rate</div>
            <h3>Response coverage</h3>
            <p>How many completed sessions have feedback recorded.</p>
            <div class="response-wrap">
              <div>
                <div class="response-score">{{responseRate.value}}%</div>
                <div class="response-meta">{{responseRate.label}}</div>
              </div>
              <div class="response-status {{responseRate.statusClass}}">
                {{responseRate.target}}
              </div>
            </div>
            <div class="response-bar">
              <div class="response-fill {{responseRate.statusClass}}" style="width: {{responseRate.value}}%;"></div>
            </div>
          </div>
        </div>
        <div class="col-lg-7">
          <div class="chart-card">
            <div class="section-kicker"><i class="bi bi-filter-circle"></i> Session Funnel</div>
            <h3>From request to feedback</h3>
            <p>Conversion rates show where sessions drop off between steps.</p>
            <div class="funnel-list">
              {{#each funnelSteps}}
              <div class="funnel-step">
                <div class="funnel-label">{{this.label}}</div>
                <div class="funnel-count">{{this.count}}</div>
                {{#if this.isFirst}}
                  <div class="funnel-rate">Starting point</div>
                {{else}}
                  <div class="funnel-rate">{{this.rate}}% conversion</div>
                {{/if}}
              </div>
              {{/each}}
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="chart-card">
            <div class="section-kicker"><i class="bi bi-lightbulb"></i> Themes</div>
            <h3>Strengths and improvements</h3>
            <p>Top recurring themes pulled from recent feedback notes.</p>
            <div class="theme-block">
              <div class="theme-title">Strengths</div>
              <div class="theme-list">
                {{#if strengthThemes.length}}
                  {{#each strengthThemes}}
                  <span class="theme-chip" title="{{this.count}} mentions">{{this.label}}</span>
                  {{/each}}
                {{else}}
                  <span class="theme-chip empty">Not enough feedback yet</span>
                {{/if}}
              </div>
            </div>
            <div class="theme-block">
              <div class="theme-title">Improvements</div>
              <div class="theme-list">
                {{#if improvementThemes.length}}
                  {{#each improvementThemes}}
                  <span class="theme-chip" title="{{this.count}} mentions">{{this.label}}</span>
                  {{/each}}
                {{else}}
                  <span class="theme-chip empty">Not enough feedback yet</span>
                {{/if}}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container chart-section">
      <div class="chart-card trend-card">
        <div class="trend-top">
          <div class="trend-title">
            <div class="section-kicker"><i class="bi bi-activity"></i> Trend Snapshot</div>
            <h3>Sessions & Feedback Trends</h3>
            <p>The chart keeps the same data source and gives your metrics a cleaner presentation for faster reading.</p>
            <div class="trend-tags">
              <span class="range-pill">{{rangeLabel}}</span>
              {{#if compareEnabled}}
                <span class="range-pill">Compared to {{compareLabel}}</span>
              {{/if}}
            </div>
          </div>
          <div class="trend-stats">
            <div class="trend-stat">
              <div class="trend-stat-label">Mentees</div>
              <div class="trend-stat-value">{{stats.mentees}}</div>
            </div>
            <div class="trend-stat">
              <div class="trend-stat-label">Sessions</div>
              <div class="trend-stat-value">{{stats.sessions}}</div>
            </div>
            <div class="trend-stat">
              <div class="trend-stat-label">Avg Rating</div>
              <div class="trend-stat-value">{{stats.avgRating}}</div>
              <div class="trend-stat-meta">Based on {{stats.ratingCount}} feedback</div>
            </div>
          </div>
        </div>
        <div class="trend-legend">
          <span class="legend-item"><span class="legend-dot dot-mentees"></span>Mentees</span>
          <span class="legend-item"><span class="legend-dot dot-sessions"></span>Sessions</span>
          <span class="legend-item"><span class="legend-dot dot-rating"></span>Avg Rating</span>
        </div>
        <div class="chart-shell">
          <div class="chart-canvas">
            <canvas id="mentorChart"></canvas>
          </div>
        </div>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const ctx = document.getElementById('mentorChart');
    if (ctx) {
      const chartValues = [
        {{stats.mentees}},
        {{stats.sessions}},
        parseFloat('{{stats.avgRating}}') || 0
      ];
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Mentees', 'Sessions', 'Avg. Rating'],
          datasets: [{
            label: 'Trends',
            data: chartValues,
            backgroundColor: ['rgba(42, 157, 143, 0.85)', 'rgba(217, 178, 64, 0.85)', 'rgba(0, 119, 182, 0.85)'],
            hoverBackgroundColor: ['rgba(42, 157, 143, 1)', 'rgba(217, 178, 64, 1)', 'rgba(0, 119, 182, 1)'],
            borderWidth: 1,
            borderRadius: 14,
            borderSkipped: false,
            maxBarThickness: 72
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          layout: { padding: { top: 8, right: 8, bottom: 0, left: 8 } },
          scales: {
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1, color: '#7f8f9a' },
              grid: { color: 'rgba(0, 48, 73, 0.08)', drawBorder: false }
            },
            x: {
              ticks: { color: '#7f8f9a' },
              grid: { display: false, drawBorder: false }
            }
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: 'rgba(13, 27, 36, 0.9)',
              titleColor: '#ffffff',
              bodyColor: '#ffffff',
              padding: 12,
              callbacks: {
                label: (context) => ` ${context.parsed.y}`
              }
            }
          }
        }
      });
    }
  </script>
</body>
</html>
