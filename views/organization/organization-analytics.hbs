<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organization Analytics - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--primary-color);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1580px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--primary-color) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: rgba(0, 119, 182, 0.08);
    }

    .btn-logout {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-logout:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .stats-section,
    .chart-section {
      margin-top: 24px;
    }

    .stat-card,
    .chart-card {
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(216, 232, 240, 0.95);
      border-radius: 28px;
      box-shadow: 0 18px 40px rgba(0, 48, 73, 0.08);
    }

    .stat-card {
      padding: 26px 22px;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--secondary-color), var(--accent-color));
    }

    .stat-top {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 16px;
    }

    .stat-label {
      color: var(--muted-text);
      font-weight: 500;
      margin-bottom: 8px;
    }

    .stat-card h4 {
      font-weight: 700;
      font-size: 2.2rem;
      margin-bottom: 8px;
    }

    .stat-icon {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.55rem;
      color: #fff;
      box-shadow: 0 14px 28px rgba(0, 48, 73, 0.10);
    }

    .stat-icon.green {
      background: linear-gradient(135deg, var(--accent-color), #1f877b);
    }

    .stat-icon.yellow {
      background: linear-gradient(135deg, #d9b240, #c89200);
    }

    .stat-icon.blue {
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
    }

    .chart-card {
      padding: 28px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .chart-card h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .chart-card p {
      color: var(--muted-text);
      margin-bottom: 22px;
      line-height: 1.7;
    }

    footer {
      background: rgba(255, 255, 255, 0.88);
      border-top: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--muted-text);
      margin-top: auto;
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .chart-card {
        padding: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/org/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/org/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/org/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/org/analytics" class="nav-link active">Analytics</a></li>
            <li class="nav-item"><a href="/org/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-bar-chart-fill"></i>
          Organization Analytics
        </div>
        <h1>Understand the scale and quality of your <span>mentorship program.</span></h1>
        <p>These metrics help you see how many mentees your program supports, how active your sessions are, and how feedback is trending across the organization.</p>
      </div>
    </section>

    <section class="container stats-section">
      <div class="row text-center g-4">
        <div class="col-md-4">
          <div class="stat-card">
            <div class="stat-top">
              <div class="text-start">
                <div class="stat-label">Mentees</div>
                <h4>{{stats.mentees}}</h4>
                <p class="mb-0 text-muted">Participants currently reached by your program.</p>
              </div>
              <div class="stat-icon green"><i class="bi bi-people-fill"></i></div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card">
            <div class="stat-top">
              <div class="text-start">
                <div class="stat-label">Sessions</div>
                <h4>{{stats.sessions}}</h4>
                <p class="mb-0 text-muted">Total sessions created under your organization.</p>
              </div>
              <div class="stat-icon yellow"><i class="bi bi-calendar-event"></i></div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card">
            <div class="stat-top">
              <div class="text-start">
                <div class="stat-label">Avg. Rating</div>
                <h4>{{stats.avgRating}}</h4>
                <p class="mb-0 text-muted">Average session feedback linked to your program.</p>
              </div>
              <div class="stat-icon blue"><i class="bi bi-star-fill"></i></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container chart-section">
      <div class="chart-card">
        <div class="section-kicker"><i class="bi bi-activity"></i> Trend Snapshot</div>
        <h3>Sessions & Feedback Trends</h3>
        <p>The chart uses the same live organization stats, now presented in a cleaner, more readable analytics layout.</p>
        <canvas id="analyticsChart" height="100"></canvas>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode"></button>

  <script>
    const ctx = document.getElementById('analyticsChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Mentees', 'Sessions', 'Avg. Rating'],
          datasets: [{
            label: 'Trends',
            data: [{{stats.mentees}}, {{stats.sessions}}, {{stats.avgRating}}],
            backgroundColor: ['#2a9d8f', '#d9b240', '#0077b6'],
            borderWidth: 1,
            borderRadius: 10
          }]
        },
        options: {
          responsive: true,
          scales: {
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1 }
            }
          },
          plugins: {
            legend: { display: false }
          }
        }
      });
    }
  </script>
</body>
</html>
