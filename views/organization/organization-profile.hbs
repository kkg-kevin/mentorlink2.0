<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organization Profile - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      padding-bottom: 36px;
    }

    .page-shell .container {
      max-width: min(1720px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout,
    .btn-primary {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-logout:hover,
    .btn-primary:hover {
      transform: translateY(-2px);
      background: linear-gradient(135deg, #005f89, var(--secondary-color));
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      overflow: hidden;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .profile-card {
      margin-top: 26px;
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      box-shadow: var(--card-shadow);
      overflow: hidden;
    }

    .profile-grid {
      display: grid;
      grid-template-columns: 360px minmax(0, 1fr);
      gap: 0;
    }

    .profile-sidebar {
      padding: 34px 28px;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border-color);
      text-align: center;
    }

    .avatar-frame {
      width: 148px;
      height: 148px;
      border-radius: 34px;
      padding: 10px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.14), rgba(42, 157, 143, 0.14));
      box-shadow: 0 16px 32px rgba(0, 48, 73, 0.10);
    }

    .avatar-upload {
      display: block;
      cursor: pointer;
      transition: transform 0.25s ease;
    }

    .avatar-upload:hover {
      transform: translateY(-2px);
    }

    .profile-icon {
      width: 100%;
      height: 100%;
      border-radius: 26px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: #6f96ab;
      overflow: hidden;
    }

    .profile-icon img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      transform: scale(1.12);
    }

    .avatar-upload-note {
      margin-top: 10px;
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .visually-hidden-file-input {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .profile-name {
      font-weight: 700;
      font-size: 1.4rem;
      margin-bottom: 6px;
    }

    .profile-email {
      color: var(--text-muted);
      margin-bottom: 18px;
      word-break: break-word;
    }

    .info-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 16px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .sidebar-note {
      margin-top: 20px;
      color: var(--text-muted);
      line-height: 1.7;
      font-size: 0.94rem;
    }

    .profile-progress {
      margin-top: 22px;
      padding: 20px;
      background: var(--bg-progress);
      border-radius: 18px;
      border: 1px solid var(--border-soft);
      text-align: center;
    }

    .circular-progress {
      position: relative;
      width: 120px;
      height: 120px;
      margin: 0 auto 16px;
    }

    .circular-progress svg {
      transform: rotate(-90deg);
    }

    .progress-circle-bg {
      fill: none;
      stroke: rgba(216,232,240,0.6);
      stroke-width: 8;
    }

    .progress-circle-fill {
      fill: none;
      stroke: url(#orgGradient);
      stroke-width: 8;
      stroke-linecap: round;
      transition: stroke-dashoffset 0.6s ease;
    }

    .progress-percentage {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--secondary-color);
    }

    .progress-label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .progress-hint {
      margin-top: 12px;
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-bottom: 0;
    }

    .form-panel {
      padding: 34px 34px 30px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .form-panel h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .form-panel .section-subtitle {
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 28px;
      text-align: left;
      font-size: 1rem;
    }

    .form-label {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .form-control {
      border-radius: 18px;
      border: 1px solid var(--border-input);
      padding: 13px 16px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-control:focus {
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      outline: none;
      background-color: var(--bg-surface);
      border-color: rgba(0, 119, 182, 0.45);
    }

    textarea.form-control {
      min-height: 120px;
    }

    .field-group {
      margin-bottom: 20px;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: 42px;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.3rem;
      }

      .profile-grid {
        grid-template-columns: 1fr;
      }

      .profile-sidebar {
        border-right: none;
        border-bottom: 1px solid var(--border-color);
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .form-panel,
      .profile-sidebar {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/org/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/org/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/org/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/org/analytics" class="nav-link">Analytics</a></li>
            <li class="nav-item"><a href="/org/profile" class="nav-link active">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-building-fill-gear"></i>
          Organization Profile
        </div>
        <h1>Present a program profile that makes your <span>mentorship offering clear.</span></h1>
        <p>Keep your organization’s identity, website, and program description up to date so participants can understand what your mentorship experience offers.</p>
      </div>
    </section>

    <section class="container">
      <div class="profile-card">
        <form method="POST" action="/org/profile/update" enctype="multipart/form-data">
          <div class="profile-grid">
          <aside class="profile-sidebar">
            <label for="profilePictureInput" class="avatar-frame avatar-upload" aria-label="Choose profile picture">
              <div class="profile-icon">
                {{#if user.profilePicture}}
                  <img src="{{user.profilePicture}}" alt="{{user.name}}" id="profilePicturePreview">
                {{else}}
                  <i class="bi bi-building" id="profilePicturePlaceholder"></i>
                  <img src="" alt="{{user.name}}" id="profilePicturePreview" style="display: none;">
                {{/if}}
              </div>
            </label>
            <input id="profilePictureInput" type="file" name="profilePicture" class="visually-hidden-file-input" accept="image/*">
            <div class="avatar-upload-note">Click the photo area to upload</div>
            <div class="profile-name">{{user.name}}</div>
            <div class="profile-email">{{user.email}}</div>
            <div class="info-chip"><i class="bi bi-buildings-fill"></i> Organization Account</div>

            {{#if profileCompleteness}}
            <div class="profile-progress">
              <div class="progress-label">Profile Complete</div>
              <div class="circular-progress">
                <svg width="120" height="120">
                  <defs>
                    <linearGradient id="orgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" style="stop-color:var(--secondary-color);stop-opacity:1" />
                      <stop offset="100%" style="stop-color:var(--accent-color);stop-opacity:1" />
                    </linearGradient>
                  </defs>
                  <circle class="progress-circle-bg" cx="60" cy="60" r="52"></circle>
                  <circle class="progress-circle-fill" cx="60" cy="60" r="52"
                    stroke-dasharray="326.73"
                    stroke-dashoffset="326.73"></circle>
                </svg>
                <div class="progress-percentage">{{profileCompleteness}}%</div>
              </div>
              {{#if profileIncomplete}}
                <p class="progress-hint">Complete your profile so mentees can find and understand your program.</p>
              {{/if}}
            </div>
            {{/if}}

            <p class="sidebar-note">A polished organization profile makes your mentorship program easier to understand and more trustworthy to new participants.</p>
          </aside>

          <div class="form-panel">
            <div class="section-kicker"><i class="bi bi-pencil-square"></i> Update Details</div>
            <h3>Organization information</h3>
            <p class="section-subtitle">Refine your public-facing program details without changing the existing profile workflow.</p>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Organization Name</label>
                  <input type="text" class="form-control" value="{{user.name}}" disabled>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Email Account</label>
                  <input type="email" class="form-control" value="{{user.email}}" disabled>
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Website</label>
                <input type="url" name="website" class="form-control" value="{{organization.website}}" placeholder="https://organization.com">
              </div>

              <div class="field-group">
                <label class="form-label">Program Name</label>
                <input type="text" name="programName" class="form-control" value="{{organization.programName}}" placeholder="e.g. Leadership Pathways, Future Engineers">
              </div>

              <div class="field-group">
                <label class="form-label">Program Description</label>
                <textarea name="description" class="form-control" rows="4" placeholder="Describe your mentorship program">{{organization.description}}</textarea>
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Location</label>
                  <input type="text" name="location" class="form-control" value="{{organization.location}}" placeholder="e.g. New York, Remote">
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">LinkedIn Profile</label>
                  <input type="url" name="linkedinProfile" class="form-control" value="{{organization.linkedinProfile}}" placeholder="https://linkedin.com/company/...">
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Focus Areas <span style="font-weight:400;color:var(--muted-text);">(comma-separated)</span></label>
                <input type="text" name="focusAreas" class="form-control" value="{{#each organization.focusAreas}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}" placeholder="e.g. Technology, Finance, Healthcare">
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Program Type</label>
                  <select name="programType" class="form-control">
                    <option value="">Select type...</option>
                    <option value="bootcamp" {{#ifEq organization.programType "bootcamp"}}selected{{/ifEq}}>Bootcamp</option>
                    <option value="internship" {{#ifEq organization.programType "internship"}}selected{{/ifEq}}>Internship</option>
                    <option value="mentorship-circle" {{#ifEq organization.programType "mentorship-circle"}}selected{{/ifEq}}>Mentorship Circle</option>
                    <option value="one-on-one" {{#ifEq organization.programType "one-on-one"}}selected{{/ifEq}}>One-on-One</option>
                    <option value="workshop" {{#ifEq organization.programType "workshop"}}selected{{/ifEq}}>Workshop</option>
                  </select>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Session Format</label>
                  <select name="sessionFormat" class="form-control">
                    <option value="">Select format...</option>
                    <option value="online" {{#ifEq organization.sessionFormat "online"}}selected{{/ifEq}}>Online</option>
                    <option value="in-person" {{#ifEq organization.sessionFormat "in-person"}}selected{{/ifEq}}>In-Person</option>
                    <option value="hybrid" {{#ifEq organization.sessionFormat "hybrid"}}selected{{/ifEq}}>Hybrid</option>
                  </select>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Target Level</label>
                  <select name="targetLevel" class="form-control">
                    <option value="">Select level...</option>
                    <option value="beginner" {{#ifEq organization.targetLevel "beginner"}}selected{{/ifEq}}>Beginner</option>
                    <option value="intermediate" {{#ifEq organization.targetLevel "intermediate"}}selected{{/ifEq}}>Intermediate</option>
                    <option value="advanced" {{#ifEq organization.targetLevel "advanced"}}selected{{/ifEq}}>Advanced</option>
                    <option value="all-levels" {{#ifEq organization.targetLevel "all-levels"}}selected{{/ifEq}}>All Levels</option>
                  </select>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Program Duration</label>
                  <input type="text" name="programDuration" class="form-control" value="{{organization.programDuration}}" placeholder="e.g. 3 months, Ongoing">
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Member Capacity</label>
                  <input type="number" name="memberCapacity" class="form-control" value="{{organization.memberCapacity}}" placeholder="Max number of members" min="0">
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Open to New Members</label>
                  <select name="openToNewMembers" class="form-control">
                    <option value="on" {{#if organization.openToNewMembers}}selected{{/if}}>Yes — accepting new members</option>
                    <option value="false" {{#unless organization.openToNewMembers}}selected{{/unless}}>No — program is full</option>
                  </select>
                </div>
              </div>

              <button type="submit" class="btn btn-primary px-4 py-3">Save Profile</button>
          </div>
          </div>
        </form>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Animate circular progress bar
    document.addEventListener('DOMContentLoaded', function() {
      const progressFill = document.querySelector('.progress-circle-fill');
      const percentageText = document.querySelector('.progress-percentage');

      if (progressFill && percentageText) {
        const percentage = parseInt(percentageText.textContent);
        const circumference = 2 * Math.PI * 52;
        const offset = circumference - (percentage / 100) * circumference;
        setTimeout(() => {
          progressFill.style.strokeDashoffset = offset;
        }, 300);
      }
    });

    const organizationProfileInput = document.getElementById('profilePictureInput');
    const organizationProfilePreview = document.getElementById('profilePicturePreview');
    const organizationProfilePlaceholder = document.getElementById('profilePicturePlaceholder');

    if (organizationProfileInput && organizationProfilePreview) {
      organizationProfileInput.addEventListener('change', (event) => {
        const [file] = event.target.files;

        if (!file) {
          return;
        }

        organizationProfilePreview.src = URL.createObjectURL(file);
        organizationProfilePreview.style.display = 'block';

        if (organizationProfilePlaceholder) {
          organizationProfilePlaceholder.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
