<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MentorLink | Conversation</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1760px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--primary-color) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-logout:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 28px 0;
      border-radius: 30px;
      background: var(--bg-hero);
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 220px;
      height: 220px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .hero-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .hero-avatar {
      width: 64px;
      height: 64px;
      border-radius: 20px;
      object-fit: cover;
      box-shadow: 0 14px 26px rgba(0, 48, 73, 0.12);
    }

    .hero-title {
      font-weight: 700;
      margin: 0;
    }

    .hero-subtitle {
      color: var(--muted-text);
      margin: 4px 0 0;
    }

    .messages-panel {
      margin-top: 24px;
    }

    .chat-card,
    .empty-state {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 26px;
      box-shadow: var(--card-shadow);
    }

    .chat-card {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 18px;
      min-height: 520px;
    }

    .message-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 520px;
      overflow-y: auto;
      padding-right: 6px;
    }

    .message-row {
      display: flex;
      gap: 12px;
      align-items: flex-end;
    }

    .message-row.is-own {
      justify-content: flex-end;
    }

    .message-bubble {
      max-width: min(70%, 520px);
      padding: 12px 16px;
      border-radius: 18px;
      background: var(--bg-chip);
      color: var(--text-primary);
      box-shadow: 0 12px 24px rgba(0, 48, 73, 0.10);
    }

    .message-bubble.outgoing {
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.18), rgba(42, 157, 143, 0.14));
    }

    .message-bubble.incoming {
      background: var(--bg-surface);
      border: 1px solid var(--border-color);
    }

    .message-meta {
      margin-top: 6px;
      font-size: 0.78rem;
      color: var(--muted-text);
    }

    .message-avatar {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      object-fit: cover;
      box-shadow: 0 10px 18px rgba(0, 48, 73, 0.12);
    }

    .message-row.is-own .message-avatar {
      order: 2;
    }

    .compose-card {
      display: flex;
      gap: 12px;
      align-items: flex-end;
      border-top: 1px solid var(--border-color);
      padding-top: 16px;
    }

    .compose-card textarea {
      flex: 1;
      min-height: 76px;
      resize: vertical;
    }

    .form-control {
      border-radius: 14px;
      border: 1px solid var(--border-input);
      padding: 10px 14px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-control:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem var(--card-glow);
      background: var(--bg-surface);
    }

    .btn-primary {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
      padding: 10px 20px;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
    }

    .empty-state {
      padding: 30px 24px;
      text-align: center;
    }

    .empty-state i {
      font-size: 2.2rem;
      color: var(--secondary-color);
      margin-bottom: 12px;
      display: inline-block;
    }

    .empty-state h5 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .empty-state p {
      color: var(--muted-text);
      margin: 0;
    }

    footer {
      background: rgba(255, 255, 255, 0.88);
      border-top: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--muted-text);
      margin-top: auto;
    }

    @media (max-width: 992px) {
      .message-bubble {
        max-width: 85%;
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
      }

      .chat-card {
        min-height: 420px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="{{#ifEq user.role "mentee"}}/mentee/dashboard{{else}}/mentor/dashboard{{/ifEq}}">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="menu">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            {{#ifEq user.role "mentee"}}
              <li class="nav-item"><a href="/mentee/dashboard" class="nav-link">Dashboard</a></li>
              <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
              <li class="nav-item"><a href="/messages" class="nav-link active">Messages</a></li>
              <li class="nav-item"><a href="/mentee/feedback" class="nav-link">Feedback</a></li>
              <li class="nav-item"><a href="/mentee/profile" class="nav-link">Profile</a></li>
            {{/ifEq}}
            {{#ifEq user.role "mentor"}}
              <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
              <li class="nav-item"><a href="/mentor/sessions" class="nav-link">Sessions</a></li>
              <li class="nav-item"><a href="/messages" class="nav-link active">Messages</a></li>
              <li class="nav-item"><a href="/mentor/analytics" class="nav-link">Analytics</a></li>
              <li class="nav-item"><a href="/mentor/profile" class="nav-link">Profile</a></li>
            {{/ifEq}}
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-left">
          <img class="hero-avatar" src="{{otherUser.avatar}}" alt="{{otherUser.name}}">
          <div>
            <h3 class="hero-title">{{otherUser.name}}</h3>
            {{#if otherUser.role}}
              <p class="hero-subtitle">{{otherUser.role}}</p>
            {{/if}}
          </div>
        </div>
        <a href="/messages" class="btn btn-outline-secondary">Back to Messages</a>
      </div>
    </section>

    <section class="container messages-panel">
      <div class="chat-card">
        {{#if hasMessages}}
          <div class="message-list">
            {{#each messages}}
            <div class="message-row {{#if isOwn}}is-own{{/if}}">
              <img class="message-avatar" src="{{senderAvatar}}" alt="{{senderName}}">
              <div class="message-bubble {{#if isOwn}}outgoing{{else}}incoming{{/if}}">
                <div>{{body}}</div>
                <div class="message-meta">{{formatTime createdAt}} · {{formatDate createdAt}}</div>
              </div>
            </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state">
            <i class="bi bi-chat-left-text"></i>
            <h5>No messages yet</h5>
            <p>Send the first message to get the conversation started.</p>
          </div>
        {{/if}}

        <form class="compose-card" method="POST" action="/messages/{{threadId}}/send">
          <textarea name="body" class="form-control" placeholder="Write your message..." required></textarea>
          <button type="submit" class="btn btn-primary">Send</button>
        </form>
      </div>
    </section>

    <footer>
      <div class="container">
        &copy; 2025 MentorLink. All rights reserved.
      </div>
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode"></button>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
