<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MentorLink | Messages</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1760px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--primary-color) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-logout:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background: var(--bg-hero);
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 260px;
      height: 260px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .messages-panel {
      margin-top: 24px;
    }

    .panel-card,
    .thread-card,
    .empty-state {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 26px;
      box-shadow: var(--card-shadow);
    }

    .panel-card {
      padding: 24px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-chip);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .panel-card h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .panel-card p {
      color: var(--muted-text);
      margin-bottom: 18px;
    }

    .form-select,
    .form-control {
      border-radius: 14px;
      border: 1px solid var(--border-input);
      padding: 10px 14px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-select:focus,
    .form-control:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem var(--card-glow);
      background: var(--bg-surface);
    }

    .btn-primary {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
      transition: all 0.25s ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
    }

    .thread-list {
      display: grid;
      gap: 14px;
    }

    .thread-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px 20px;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      text-decoration: none;
      color: inherit;
    }

    .thread-card:hover {
      transform: translateY(-3px);
      border-color: var(--border-input);
      box-shadow: 0 18px 36px rgba(0, 48, 73, 0.10);
    }

    .thread-left {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .thread-avatar {
      width: 54px;
      height: 54px;
      border-radius: 18px;
      object-fit: cover;
      box-shadow: 0 12px 22px rgba(0, 48, 73, 0.10);
    }

    .thread-title {
      font-weight: 700;
      margin-bottom: 4px;
    }

    .thread-preview {
      color: var(--muted-text);
      font-size: 0.92rem;
      margin: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 520px;
    }

    .thread-meta {
      text-align: right;
      color: var(--muted-text);
      font-size: 0.88rem;
      white-space: nowrap;
    }

    .unread-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      padding: 0 8px;
      border-radius: 999px;
      background: rgba(42, 157, 143, 0.16);
      color: #17675e;
      font-weight: 700;
      font-size: 0.82rem;
      margin-top: 8px;
    }

    .empty-state {
      padding: 30px 24px;
      text-align: center;
    }

    .empty-state i {
      font-size: 2.2rem;
      color: var(--secondary-color);
      margin-bottom: 12px;
      display: inline-block;
    }

    .empty-state h5 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .empty-state p {
      color: var(--muted-text);
      margin: 0;
    }

    footer {
      background: rgba(255, 255, 255, 0.88);
      border-top: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--muted-text);
      margin-top: auto;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.2rem;
      }

      .thread-preview {
        max-width: 320px;
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .thread-card {
        flex-direction: column;
        align-items: flex-start;
      }

      .thread-meta {
        text-align: left;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="{{#ifEq user.role "mentee"}}/mentee/dashboard{{else}}/mentor/dashboard{{/ifEq}}">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="menu">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            {{#ifEq user.role "mentee"}}
              <li class="nav-item"><a href="/mentee/dashboard" class="nav-link">Dashboard</a></li>
              <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
              <li class="nav-item"><a href="/messages" class="nav-link active">Messages</a></li>
              <li class="nav-item"><a href="/mentee/feedback" class="nav-link">Feedback</a></li>
              <li class="nav-item"><a href="/mentee/profile" class="nav-link">Profile</a></li>
            {{/ifEq}}
            {{#ifEq user.role "mentor"}}
              <li class="nav-item"><a href="/mentor/dashboard" class="nav-link">Dashboard</a></li>
              <li class="nav-item"><a href="/mentor/sessions" class="nav-link">Sessions</a></li>
              <li class="nav-item"><a href="/messages" class="nav-link active">Messages</a></li>
              <li class="nav-item"><a href="/mentor/analytics" class="nav-link">Analytics</a></li>
              <li class="nav-item"><a href="/mentor/profile" class="nav-link">Profile</a></li>
            {{/ifEq}}
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-chat-dots-fill"></i>
          Messages Hub
        </div>
        <h1>Stay connected with your <span>mentorship partners.</span></h1>
        <p>Start a new conversation or continue recent discussions with people you have already met through sessions.</p>
      </div>
    </section>

    <section class="container messages-panel">
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="panel-card">
            <div class="section-kicker"><i class="bi bi-person-plus-fill"></i> Start Chat</div>
            <h3>Start a new conversation</h3>
            <p>Select a mentor or mentee you have already connected with to begin messaging.</p>
            {{#if hasConnections}}
              <form method="POST" action="/messages/start">
                <div class="mb-3">
                  <label for="targetUserId" class="form-label fw-semibold">Choose a connection</label>
                  <select class="form-select" id="targetUserId" name="targetUserId" required>
                    {{#each connections}}
                      <option value="{{userId}}">{{name}} ({{role}})</option>
                    {{/each}}
                  </select>
                </div>
                <button type="submit" class="btn btn-primary w-100">Start Conversation</button>
              </form>
            {{else}}
              <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No connections yet</h5>
                <p>Once you have a session with a mentor or mentee, you will be able to start messaging them here.</p>
              </div>
            {{/if}}
          </div>
        </div>
        <div class="col-lg-8">
          <div class="panel-card">
            <div class="section-kicker"><i class="bi bi-chat-heart-fill"></i> Recent Threads</div>
            <h3>Your conversations</h3>
            <p>Open a thread to pick up where you left off.</p>
            {{#if hasThreads}}
              <div class="thread-list">
                {{#each threads}}
                <a class="thread-card" href="/messages/{{id}}">
                  <div class="thread-left">
                    <img class="thread-avatar" src="{{otherAvatar}}" alt="{{otherName}}">
                    <div>
                      <div class="thread-title">{{otherName}}</div>
                      <p class="thread-preview">{{lastMessagePreview}}</p>
                    </div>
                  </div>
                  <div class="thread-meta">
                    <div>{{formatDate lastMessageAt}}</div>
                    <div>{{formatTime lastMessageAt}}</div>
                    {{#if unreadCount}}
                      <div class="unread-badge">{{unreadCount}}</div>
                    {{/if}}
                  </div>
                </a>
                {{/each}}
              </div>
            {{else}}
              <div class="empty-state">
                <i class="bi bi-chat"></i>
                <h5>No conversations yet</h5>
                <p>Start a new chat to see your conversations here.</p>
              </div>
            {{/if}}
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="container">
        &copy; 2025 MentorLink. All rights reserved.
      </div>
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode"></button>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
