<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MentorLink | Register</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.18), transparent 30%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.16), transparent 32%),
        var(--bg-base);
      min-height: 100vh;
    }
    .signup-shell {
      max-width: 960px;
    }
    .signup-card {
      border: none;
      border-radius: 28px;
      box-shadow: var(--card-shadow);
      overflow: hidden;
      background: var(--bg-surface-alt);
      backdrop-filter: blur(10px);
    }
    .intro-panel {
      background: linear-gradient(160deg, #003049 0%, #005f89 52%, #2a9d8f 100%);
      color: white;
      padding: 42px 34px;
      height: 100%;
      position: relative;
      overflow: hidden;
    }
    .intro-panel::before {
      content: '';
      position: absolute;
      width: 220px;
      height: 220px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 28px;
      top: -70px;
      right: -50px;
      transform: rotate(18deg);
    }
    .intro-panel::after {
      content: '';
      position: absolute;
      width: 180px;
      height: 180px;
      background: rgba(244, 211, 94, 0.12);
      border-radius: 50%;
      bottom: -60px;
      left: -30px;
    }
    .intro-panel > * {
      position: relative;
      z-index: 1;
    }
    .step-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 0.82rem;
      font-weight: 600;
      background: rgba(255, 255, 255, 0.14);
      margin-bottom: 18px;
    }
    .panel-note {
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.96rem;
      line-height: 1.7;
    }
    .role-points {
      margin-top: 26px;
      padding-left: 0;
      list-style: none;
    }
    .role-points li {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 14px;
      color: rgba(255, 255, 255, 0.88);
      font-size: 0.94rem;
    }
    .role-points i {
      color: var(--warm-color);
      margin-top: 2px;
    }
    .form-panel {
      padding: 38px 34px;
    }
    .brand-mark {
      max-width: 84px;
      border-radius: 20px;
      box-shadow: 0 10px 24px rgba(0, 48, 73, 0.12);
    }
    .section-title {
      color: var(--text-primary);
      font-weight: 700;
      margin-bottom: 8px;
    }
    .section-copy {
      color: var(--text-muted);
      font-size: 0.95rem;
    }
    .step-indicator {
      display: flex;
      gap: 10px;
      margin: 24px 0 22px;
    }
    .step-pill {
      flex: 1;
      border-radius: 999px;
      padding: 10px 14px;
      font-size: 0.84rem;
      font-weight: 600;
      text-align: center;
      background: var(--bg-chip);
      color: var(--text-muted);
      transition: all 0.25s ease;
    }
    .step-pill.active {
      background: var(--secondary-color);
      color: white;
      box-shadow: 0 10px 20px rgba(0, 119, 182, 0.18);
    }
    .role-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-top: 24px;
    }
    .role-card {
      border: 2px solid var(--border-input);
      border-radius: 22px;
      background: var(--bg-surface);
      padding: 20px 18px;
      text-align: left;
      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      width: 100%;
    }
    .role-card:hover {
      transform: translateY(-4px);
      border-color: var(--secondary-color);
      box-shadow: 0 14px 30px var(--card-glow);
    }
    .role-card.selected {
      border-color: var(--secondary-color);
      box-shadow: 0 16px 34px var(--card-glow);
      background: var(--bg-surface-soft);
    }
    .role-icon {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 16px;
    }
    .role-card[data-role="mentee"] .role-icon {
      background: rgba(0, 119, 182, 0.12);
      color: var(--secondary-color);
    }
    .role-card[data-role="mentor"] .role-icon {
      background: rgba(42, 157, 143, 0.14);
      color: var(--accent-color);
    }
    .role-card[data-role="organization"] .role-icon {
      background: rgba(244, 211, 94, 0.22);
      color: #9c7400;
    }
    .role-title {
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
    }
    .role-description {
      color: var(--text-muted);
      font-size: 0.9rem;
      line-height: 1.55;
      margin-bottom: 0;
    }
    .selected-role-banner {
      display: none;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      border-radius: 18px;
      background: var(--bg-chip);
      border: 1px solid var(--border-input);
      padding: 14px 16px;
      margin-bottom: 18px;
    }
    .selected-role-banner.visible {
      display: flex;
    }
    .selected-role-copy {
      color: var(--text-muted);
      font-size: 0.92rem;
      margin: 0;
    }
    .selected-role-copy strong {
      color: var(--text-primary);
    }
    .btn-change-role {
      border: none;
      background: transparent;
      color: var(--secondary-color);
      font-weight: 600;
      padding: 0;
      white-space: nowrap;
    }
    .form-step {
      display: none;
    }
    .form-step.active {
      display: block;
    }
    .form-label {
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 8px;
    }
    .form-control {
      border-radius: 16px;
      border: 1px solid var(--border-input);
      padding: 12px 15px;
      background: var(--bg-input);
      color: var(--text-primary);
    }
    .form-control:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem var(--card-glow);
      background: var(--bg-surface);
      color: var(--text-primary);
    }
    .password-field {
      position: relative;
    }
    .password-field .form-control {
      padding-right: 48px;
    }
    .password-toggle {
      position: absolute;
      top: 50%;
      right: 14px;
      transform: translateY(-50%);
      border: none;
      background: transparent;
      color: #60717a;
      padding: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      line-height: 1;
    }
    .password-toggle:hover {
      color: var(--secondary-color);
    }
    .password-toggle:focus {
      outline: none;
      color: var(--secondary-color);
    }
    .btn-primary,
    .btn-success {
      border: none;
      border-radius: 999px;
      padding: 12px 18px;
      font-weight: 600;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
    }
    .btn-success {
      background: linear-gradient(135deg, var(--accent-color), #218a7d);
    }
    .btn-ghost {
      border-radius: 999px;
      padding: 12px 18px;
      font-weight: 600;
      border: 1px solid var(--border-input);
      background: var(--bg-surface);
      color: var(--text-primary);
    }
    @media (max-width: 991px) {
      .intro-panel {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
      }
    }
    @media (max-width: 767px) {
      .role-grid {
        grid-template-columns: 1fr;
      }
      .form-panel,
      .intro-panel {
        padding: 28px 22px;
      }
      .step-indicator {
        flex-direction: column;
      }
      .selected-role-banner {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body class="d-flex justify-content-center align-items-center min-vh-100 py-4">
  <div class="container signup-shell">
    <div class="card signup-card">
      <div class="row g-0">
        <div class="col-lg-5">
          <div class="intro-panel">
            <div class="step-badge">
              <i class="bi bi-compass"></i>
              Guided Signup
            </div>
            <h2 class="fw-bold mb-3">Choose how you want to use MentorLink.</h2>
            <p class="panel-note mb-0">
              We'll guide you through a short two-step registration so your account starts in the right place.
            </p>
            <ul class="role-points">
              <li><i class="bi bi-check-circle-fill"></i><span>Mentees discover mentors, request sessions, and track growth.</span></li>
              <li><i class="bi bi-check-circle-fill"></i><span>Mentors share expertise, accept requests, and guide learners.</span></li>
              <li><i class="bi bi-check-circle-fill"></i><span>Organizations manage mentorship programs at scale.</span></li>
            </ul>
          </div>
        </div>
        <div class="col-lg-7">
          <div class="form-panel">
            <div class="text-center mb-2">
              <img src="/images/Logo 1.png" alt="MentorLink Logo" class="brand-mark mb-3">
              <h2 class="section-title">Create your MentorLink account</h2>
              <p class="section-copy mb-0">Start with your role, then finish your details.</p>
            </div>

            <div class="step-indicator">
              <div class="step-pill active" id="roleStepPill">1. Choose Role</div>
              <div class="step-pill" id="detailsStepPill">2. Account Details</div>
            </div>

            <div class="form-step active" id="roleStep">
              <div class="role-grid">
                <button type="button" class="role-card" data-role="mentee" data-label="Mentee" data-copy="Find mentors, book sessions, and grow your skills with guided support.">
                  <span class="role-icon"><i class="bi bi-mortarboard-fill"></i></span>
                  <div class="role-title">Mentee</div>
                  <p class="role-description">Looking for guidance, career support, or someone to help you grow.</p>
                </button>
                <button type="button" class="role-card" data-role="mentor" data-label="Mentor" data-copy="Share your experience, support mentees, and build meaningful impact.">
                  <span class="role-icon"><i class="bi bi-lightbulb-fill"></i></span>
                  <div class="role-title">Mentor</div>
                  <p class="role-description">Ready to guide others with your knowledge, experience, and perspective.</p>
                </button>
                <button type="button" class="role-card" data-role="organization" data-label="Organization" data-copy="Run structured programs and support mentorship at scale.">
                  <span class="role-icon"><i class="bi bi-buildings-fill"></i></span>
                  <div class="role-title">Organization</div>
                  <p class="role-description">Managing a mentorship initiative, talent program, or partner network.</p>
                </button>
              </div>
              <button type="button" class="btn btn-primary w-100 mt-4" id="continueButton" disabled>Continue</button>
            </div>

            <div class="form-step" id="detailsStep">
              <div class="selected-role-banner" id="selectedRoleBanner">
                <p class="selected-role-copy mb-0">
                  Registering as <strong id="selectedRoleLabel">Role</strong>.
                  <span id="selectedRoleCopy"></span>
                </p>
                <button type="button" class="btn-change-role" id="changeRoleButton">Change role</button>
              </div>

              <form method="POST" action="/auth/signup" autocomplete="off">
                <input type="hidden" id="registerRole" name="role" required>

                <div class="mb-3">
                  <label for="registerName" class="form-label">Full Name</label>
                  <input type="text" class="form-control" id="registerName" name="name" placeholder="Enter your name" required>
                </div>
                <div class="mb-3">
                  <label for="registerEmail" class="form-label">Email address</label>
                  <input type="email" class="form-control" id="registerEmail" name="email" placeholder="Enter your email" required>
                </div>
                <div class="mb-3">
                  <label for="registerPassword" class="form-label">Password</label>
                  <div class="password-field">
                    <input type="password" class="form-control" id="registerPassword" name="password" placeholder="Create a password" required>
                    <button type="button" class="password-toggle" data-target="registerPassword" aria-label="Show password" aria-pressed="false">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                  <button type="button" class="btn btn-ghost flex-fill" id="backButton">Back</button>
                  <button type="submit" class="btn btn-success flex-fill">Create Account</button>
                </div>
              </form>
            </div>

            <div class="small text-center mt-4">
              Already a member? <a href="/auth/login" class="fw-semibold">Login</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <footer class="mt-4 text-center text-muted small">
      &copy; 2025 MentorLink
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const roleCards = document.querySelectorAll('.role-card');
    const continueButton = document.getElementById('continueButton');
    const backButton = document.getElementById('backButton');
    const changeRoleButton = document.getElementById('changeRoleButton');
    const roleStep = document.getElementById('roleStep');
    const detailsStep = document.getElementById('detailsStep');
    const roleStepPill = document.getElementById('roleStepPill');
    const detailsStepPill = document.getElementById('detailsStepPill');
    const registerRole = document.getElementById('registerRole');
    const selectedRoleBanner = document.getElementById('selectedRoleBanner');
    const selectedRoleLabel = document.getElementById('selectedRoleLabel');
    const selectedRoleCopy = document.getElementById('selectedRoleCopy');

    let selectedRole = null;

    function selectRole(card) {
      roleCards.forEach((roleCard) => roleCard.classList.remove('selected'));
      card.classList.add('selected');
      selectedRole = card.dataset.role;
      registerRole.value = selectedRole;
      selectedRoleLabel.textContent = card.dataset.label;
      selectedRoleCopy.textContent = card.dataset.copy;
      continueButton.disabled = false;
    }

    function showDetailsStep() {
      if (!selectedRole) return;
      roleStep.classList.remove('active');
      detailsStep.classList.add('active');
      roleStepPill.classList.remove('active');
      detailsStepPill.classList.add('active');
      selectedRoleBanner.classList.add('visible');
    }

    function showRoleStep() {
      detailsStep.classList.remove('active');
      roleStep.classList.add('active');
      detailsStepPill.classList.remove('active');
      roleStepPill.classList.add('active');
      selectedRoleBanner.classList.remove('visible');
    }

    roleCards.forEach((card) => {
      card.addEventListener('click', () => selectRole(card));
    });

    continueButton.addEventListener('click', showDetailsStep);
    backButton.addEventListener('click', showRoleStep);
    changeRoleButton.addEventListener('click', showRoleStep);

    document.querySelectorAll('.password-toggle').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const targetInput = document.getElementById(toggle.dataset.target);
        if (!targetInput) return;
        const isVisible = targetInput.type === 'text';
        const icon = toggle.querySelector('i');

        targetInput.type = isVisible ? 'password' : 'text';
        toggle.setAttribute('aria-label', isVisible ? 'Show password' : 'Hide password');
        toggle.setAttribute('aria-pressed', String(!isVisible));

        if (icon) {
          icon.className = isVisible ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
      });
    });
  </script>
  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
</body>
</html>
