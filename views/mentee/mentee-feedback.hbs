<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Provide Feedback - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .page-shell .container {
      max-width: min(1740px, calc(100vw - 24px));
    }

    .navbar {
      margin: 12px 6px 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout,
    .btn-submit {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-submit {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-logout:hover,
    .btn-submit:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .feedback-layout {
      margin-top: 24px;
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.95fr);
      gap: 24px;
      align-items: start;
    }

    .feedback-card,
    .recent-feedback,
    .empty-history {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      box-shadow: var(--card-shadow);
    }

    .feedback-card,
    .recent-feedback {
      padding: 28px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    h3,
    h4,
    h5 {
      font-weight: 700;
    }

    .intro-copy,
    .form-text,
    .feedback-comment,
    .empty-history p {
      color: var(--text-muted);
      line-height: 1.7;
    }

    .form-label {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .form-select,
    .form-control {
      border-radius: 18px;
      border: 1px solid var(--border-input);
      padding: 13px 16px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-select:focus,
    .form-control:focus {
      border-color: rgba(0, 119, 182, 0.45);
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      background: var(--bg-surface);
    }

    .star-rating {
      display: flex;
      flex-direction: row-reverse;
      justify-content: center;
      gap: 8px;
      margin: 14px 0 10px;
    }

    .star-rating input {
      display: none;
    }

    .star-rating label {
      font-size: 2.2rem;
      color: #d8dee4;
      cursor: pointer;
      transition: transform 0.2s ease, color 0.2s ease;
      line-height: 1;
    }

    .star-rating label:hover {
      transform: scale(1.08);
    }

    .star-rating label:hover,
    .star-rating label:hover ~ label,
    .star-rating input:checked ~ label {
      color: #ffc107;
    }

    .rating-labels {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      color: var(--muted-text);
      font-size: 0.82rem;
    }

    .feedback-item {
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 14px;
    }

    .feedback-item:last-child {
      margin-bottom: 0;
    }

    .feedback-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 12px;
      margin-bottom: 10px;
    }

    .feedback-mentor {
      font-weight: 600;
    }

    .feedback-date {
      color: var(--text-muted);
      font-size: 0.88rem;
    }

    .empty-history {
      padding: 34px 24px;
      text-align: center;
    }

    .empty-history i {
      font-size: 2.2rem;
      color: var(--secondary-color);
      margin-bottom: 12px;
      display: inline-block;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: auto;
    }

    @media (max-width: 992px) {
      .feedback-layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
        margin: 8px 4px 0;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .feedback-card,
      .recent-feedback {
        padding: 20px;
      }

      .feedback-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/mentee/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentee/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/mentee/feedback" class="nav-link active">Feedback</a></li>
            <li class="nav-item"><a href="/mentee/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-chat-heart-fill"></i>
          Feedback Center
        </div>
        <h1>Reflect on mentorship sessions and <span>share what helped.</span></h1>
        <p>Submit thoughtful feedback after completed sessions so mentors and organizations can keep improving the experience around your growth.</p>
      </div>
    </section>

    <section class="container mt-4">
      <div id="alertContainer"></div>

      <div class="feedback-layout">
        <div class="feedback-card">
          <div class="section-kicker"><i class="bi bi-pencil-square"></i> New Feedback</div>
          <h3 class="mb-2">Submit your feedback</h3>
          <p class="intro-copy mb-4">Choose a completed session, rate the experience, and leave comments that are useful and specific.</p>

          <form method="POST" action="/mentee/feedback/submit" id="feedbackForm">
            <div class="mb-4">
              <label class="form-label"><i class="bi bi-person-circle me-2"></i>Select Session to Review</label>
              <select name="sessionId" class="form-select" id="sessionSelect" required>
                <option value="" selected>Choose a completed session...</option>
                {{#each sessions}}
                {{#unless hasFeedback}}
                <option value="{{_id}}" data-mentor-id="{{#if mentor.user}}{{mentor.user._id}}{{else}}{{organization.user._id}}{{/if}}">
                  {{#if organization}}
                    Organization: {{#if organization.user}}{{organization.user.name}}{{else if organization.programName}}{{organization.programName}}{{else}}Organization{{/if}} - {{formatDate scheduledAt}}
                  {{else if mentor}}
                    Mentor: {{#if mentor.user}}{{mentor.user.name}}{{else}}Mentor{{/if}} - {{formatDate scheduledAt}}
                  {{else}}
                    Session - {{formatDate scheduledAt}}
                  {{/if}}
                </option>
                {{/unless}}
                {{/each}}
              </select>
              <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Select who you want to give feedback to. Only sessions without feedback are shown.</div>
            </div>

            <input type="hidden" name="to" id="mentorIdField">

            <div class="mb-4">
              <label class="form-label"><i class="bi bi-star me-2"></i>Your Rating</label>
              <div class="star-rating">
                <input type="radio" name="rating" id="star5" value="5" required><label for="star5">&#9733;</label>
                <input type="radio" name="rating" id="star4" value="4"><label for="star4">&#9733;</label>
                <input type="radio" name="rating" id="star3" value="3"><label for="star3">&#9733;</label>
                <input type="radio" name="rating" id="star2" value="2"><label for="star2">&#9733;</label>
                <input type="radio" name="rating" id="star1" value="1"><label for="star1">&#9733;</label>
              </div>
              <div class="rating-labels">
                <span>Poor</span>
                <span>Fair</span>
                <span>Good</span>
                <span>Very Good</span>
                <span>Excellent</span>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label"><i class="bi bi-chat-left-text me-2"></i>Your Comments</label>
              <textarea name="comment" class="form-control" rows="5" placeholder="Share your experience... What did you like? What could be improved?" required></textarea>
              <div class="form-text mt-2"><i class="bi bi-lightbulb me-1"></i>Your feedback helps improve the mentorship experience for everyone.</div>
            </div>

            <button type="submit" class="btn btn-submit px-4 py-3">
              <i class="bi bi-send me-2"></i>Submit Feedback
            </button>
          </form>
        </div>

        <div>
          {{#if feedbacks}}
          <div class="recent-feedback">
            <div class="section-kicker"><i class="bi bi-clock-history"></i> History</div>
            <h4 class="mb-2">Your recent feedback</h4>
            <p class="intro-copy mb-4">A quick view of what you have already shared with mentors and organizations.</p>
            {{#each feedbacks}}
            <div class="feedback-item">
              <div class="feedback-header">
                <span class="feedback-mentor">
                  {{#if to}}
                    {{#ifEq to.role "organization"}}
                      <i class="bi bi-building me-1"></i>Organization: {{to.name}}
                    {{else}}
                      <i class="bi bi-person me-1"></i>Mentor: {{to.name}}
                    {{/ifEq}}
                  {{else}}
                    Recipient
                  {{/if}}
                </span>
                <span class="feedback-date">{{formatDate createdAt}}</span>
              </div>
              <div class="feedback-rating">
                {{renderStars rating}}
              </div>
              <div class="feedback-comment">
                {{comment}}
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="empty-history">
            <i class="bi bi-chat-left-dots"></i>
            <h5>No feedback history yet</h5>
            <p>Your submitted feedback will appear here after you review a completed session.</p>
          </div>
          {{/if}}
        </div>
      </div>
    </section>

    <footer>
      <div class="container">
        &copy; 2025 MentorLink. All rights reserved.
      </div>
    </footer>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelector('select[name="sessionId"]').addEventListener('change', function() {
      const selectedOption = this.options[this.selectedIndex];
      if (selectedOption.dataset.mentorId) {
        document.getElementById('mentorIdField').value = selectedOption.dataset.mentorId;
      }
    });

    document.addEventListener('DOMContentLoaded', function() {
      const urlParams = new URLSearchParams(window.location.search);
      const alertContainer = document.getElementById('alertContainer');

      if (urlParams.get('success') === 'true') {
        alertContainer.innerHTML = `
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            <strong>Success!</strong> Your feedback has been submitted successfully.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        `;
        window.history.replaceState({}, document.title, window.location.pathname);
      } else if (urlParams.get('error') === 'duplicate') {
        alertContainer.innerHTML = `
          <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Already Submitted!</strong> You have already provided feedback for this session.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        `;
        window.history.replaceState({}, document.title, window.location.pathname);
      } else if (urlParams.get('error') === 'failed') {
        alertContainer.innerHTML = `
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-x-circle me-2"></i>
            <strong>Error!</strong> Failed to submit feedback. Please try again.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        `;
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      const sessionSelect = document.getElementById('sessionSelect');
      if (sessionSelect.options.length === 1) {
        alertContainer.innerHTML = `
          <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            <strong>No Sessions Available</strong> - You have either not completed any sessions yet, or you've already provided feedback for all completed sessions.
          </div>
        `;
        document.getElementById('feedbackForm').style.display = 'none';
      }
    });
  </script>
</body>
</html>
