<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mentee Profile - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #003049;
      --secondary-color: #0077b6;
      --accent-color: #2a9d8f;
      --surface-border: #d8e8f0;
      --muted-text: #61727c;
    }

    body {
      font-family: 'Poppins', sans-serif;
      color: var(--primary-color);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        #fbfeff;
      min-height: 100vh;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      padding-bottom: 36px;
    }

    .page-shell .container {
      max-width: min(1720px, calc(100vw - 24px));
    }

    .navbar {
      margin: 18px auto 0;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 14px 34px rgba(0, 48, 73, 0.08);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--primary-color) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: rgba(0, 119, 182, 0.08);
    }

    .btn-logout,
    .btn-save {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-save {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-logout:hover,
    .btn-save:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      overflow: hidden;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .profile-card {
      margin-top: 26px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(216, 232, 240, 0.95);
      border-radius: 28px;
      box-shadow: 0 18px 40px rgba(0, 48, 73, 0.08);
      overflow: hidden;
    }

    .profile-grid {
      display: grid;
      grid-template-columns: 360px minmax(0, 1fr);
      gap: 0;
    }

    .profile-sidebar {
      padding: 34px 28px;
      background: linear-gradient(180deg, rgba(246, 251, 253, 0.96), rgba(255, 255, 255, 0.94));
      border-right: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
    }

    .avatar-frame {
      width: 148px;
      height: 148px;
      border-radius: 34px;
      padding: 10px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.14), rgba(42, 157, 143, 0.14));
      box-shadow: 0 16px 32px rgba(0, 48, 73, 0.10);
    }

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 26px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: #6f96ab;
      overflow: hidden;
    }

    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-name {
      font-weight: 700;
      font-size: 1.4rem;
      margin-bottom: 6px;
    }

    .profile-email {
      color: var(--muted-text);
      margin-bottom: 18px;
      word-break: break-word;
    }

    .info-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 16px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .sidebar-note {
      margin-top: 20px;
      color: var(--muted-text);
      line-height: 1.7;
      font-size: 0.94rem;
    }

    .form-panel {
      padding: 34px 34px 30px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .form-panel h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .form-panel .subtext {
      color: var(--muted-text);
      line-height: 1.7;
      margin-bottom: 28px;
    }

    .form-label {
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 8px;
    }

    .form-control,
    .form-select {
      border-radius: 18px;
      border: 1px solid var(--surface-border);
      padding: 13px 16px;
      background: #fbfeff;
      transition: all 0.25s ease;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: rgba(0, 119, 182, 0.45);
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      background: #fff;
    }

    textarea.form-control {
      resize: vertical;
      min-height: 120px;
    }

    .field-group {
      margin-bottom: 20px;
    }

    footer {
      background: rgba(255, 255, 255, 0.88);
      border-top: 1px solid rgba(216, 232, 240, 0.95);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--muted-text);
      margin-top: 42px;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.3rem;
      }

      .profile-grid {
        grid-template-columns: 1fr;
      }

      .profile-sidebar {
        border-right: none;
        border-bottom: 1px solid rgba(216, 232, 240, 0.95);
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .form-panel,
      .profile-sidebar {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentee/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu"
          aria-controls="menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentee/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/mentee/feedback" class="nav-link">Feedback</a></li>
            <li class="nav-item"><a href="/mentee/profile" class="nav-link active">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-person-badge-fill"></i>
          Mentee Profile
        </div>
        <h1>Shape a profile that helps mentors <span>guide you well.</span></h1>
        <p>Keep your goals, skills, and contact details up to date so the people supporting you can understand where you are and where you want to go.</p>
      </div>
    </section>

    <section class="container">
      <div class="profile-card">
        <div class="profile-grid">
          <aside class="profile-sidebar">
            <div class="avatar-frame">
              <div class="avatar">
                {{#if user.profilePicture}}
                  <img src="{{user.profilePicture}}" alt="{{user.name}}" />
                {{else}}
                  <i class="bi bi-person"></i>
                {{/if}}
              </div>
            </div>
            <div class="profile-name">{{user.name}}</div>
            <div class="profile-email">{{user.email}}</div>
            <div class="info-chip"><i class="bi bi-mortarboard-fill"></i> Mentee Account</div>
            <p class="sidebar-note">A strong profile makes it easier to get useful mentorship, better context, and more relevant guidance.</p>
          </aside>

          <div class="form-panel">
            <div class="section-kicker"><i class="bi bi-pencil-square"></i> Update Details</div>
            <h3>Mentee information</h3>
            <p class="subtext">This keeps your public-facing information clear without changing any of your existing profile workflow.</p>

            <form method="POST" action="/mentee/profile/update" enctype="multipart/form-data">
              <div class="field-group">
                <label class="form-label">Profile Picture</label>
                <input type="file" name="profilePicture" class="form-control" accept="image/*" />
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Full name</label>
                  <input type="text" class="form-control" value="{{user.name}}" disabled />
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Email Account</label>
                  <input type="email" class="form-control" value="{{user.email}}" disabled />
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phone" class="form-control" value="{{mentee.phone}}" placeholder="e.g +2547..." />
              </div>

              <div class="field-group">
                <label class="form-label">Education Level</label>
                <select name="education" class="form-select">
                  <option value="">Select Level</option>
                  <option value="High School" {{#ifEq mentee.educationLevel "High School"}}selected{{/ifEq}}>High School</option>
                  <option value="Undergraduate" {{#ifEq mentee.educationLevel "Undergraduate"}}selected{{/ifEq}}>Undergraduate</option>
                  <option value="Postgraduate" {{#ifEq mentee.educationLevel "Postgraduate"}}selected{{/ifEq}}>Postgraduate</option>
                  <option value="Professional" {{#ifEq mentee.educationLevel "Professional"}}selected{{/ifEq}}>Professional</option>
                </select>
              </div>

              <div class="field-group">
                <label class="form-label">Mentorship Goal</label>
                <textarea name="goal" class="form-control" rows="3" placeholder="Describe your goals..">{{mentee.goals}}</textarea>
              </div>

              <div class="field-group">
                <label class="form-label">Skills/Interests</label>
                <textarea name="skills" class="form-control" rows="3" placeholder="List your skills or interests....">{{mentee.skills}}</textarea>
              </div>

              <button type="submit" class="btn btn-save px-4 py-3">Save Profile</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
