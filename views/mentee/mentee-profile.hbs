<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mentee Profile - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      padding-bottom: 36px;
    }

    .page-shell .container {
      max-width: min(1720px, calc(100vw - 24px));
    }

    .navbar {
      margin: 18px auto 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout,
    .btn-save {
      border-radius: 999px;
      font-weight: 600;
      border: none;
      transition: all 0.25s ease;
    }

    .btn-logout,
    .btn-save {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-logout:hover,
    .btn-save:hover {
      transform: translateY(-2px);
    }

    .page-hero {
      margin-top: 26px;
      padding: 38px 0;
      border-radius: 30px;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.16), transparent 22%),
        linear-gradient(135deg, rgba(0, 119, 182, 0.08) 0%, rgba(232, 246, 252, 0.9) 48%, rgba(255, 255, 255, 0.98) 100%);
      border: 1px solid rgba(216, 232, 240, 0.95);
      box-shadow: 0 24px 60px rgba(0, 48, 73, 0.10);
      overflow: hidden;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 250px;
      height: 250px;
      right: -70px;
      top: -90px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 36px;
      transform: rotate(18deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(216, 232, 240, 0.95);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 12px;
      font-weight: 700;
      font-size: 2.8rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .page-hero p {
      color: var(--muted-text);
      max-width: 980px;
      line-height: 1.8;
      margin: 0;
    }

    .profile-card {
      margin-top: 26px;
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 28px;
      box-shadow: var(--card-shadow);
      overflow: hidden;
    }

    .profile-grid {
      display: grid;
      grid-template-columns: 360px minmax(0, 1fr);
      gap: 0;
    }

    .profile-sidebar {
      padding: 34px 28px;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border-color);
      text-align: center;
    }

    .avatar-frame {
      width: 148px;
      height: 148px;
      border-radius: 34px;
      padding: 10px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.14), rgba(42, 157, 143, 0.14));
      box-shadow: 0 16px 32px rgba(0, 48, 73, 0.10);
    }

    .avatar-upload {
      display: block;
      cursor: pointer;
      transition: transform 0.25s ease;
    }

    .avatar-upload:hover {
      transform: translateY(-2px);
    }

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 26px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: #6f96ab;
      overflow: hidden;
    }

    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .avatar-upload-note {
      margin-top: 10px;
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .visually-hidden-file-input {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .profile-name {
      font-weight: 700;
      font-size: 1.4rem;
      margin-bottom: 6px;
    }

    .profile-email {
      color: var(--muted-text);
      margin-bottom: 18px;
      word-break: break-word;
    }

    .info-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 16px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .sidebar-note {
      margin-top: 20px;
      color: var(--muted-text);
      line-height: 1.7;
      font-size: 0.94rem;
    }

    .profile-progress {
      margin-top: 22px;
      padding: 20px;
      background: linear-gradient(135deg, rgba(0,119,182,0.06), rgba(42,157,143,0.04));
      border-radius: 18px;
      border: 1px solid rgba(216,232,240,0.7);
      text-align: center;
    }

    .circular-progress {
      position: relative;
      width: 120px;
      height: 120px;
      margin: 0 auto 16px;
    }

    .circular-progress svg {
      transform: rotate(-90deg);
    }

    .progress-circle-bg {
      fill: none;
      stroke: rgba(216,232,240,0.6);
      stroke-width: 8;
    }

    .progress-circle-fill {
      fill: none;
      stroke: url(#gradient);
      stroke-width: 8;
      stroke-linecap: round;
      transition: stroke-dashoffset 0.6s ease;
    }

    .progress-percentage {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--secondary-color);
    }

    .progress-label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--primary-color);
      margin-bottom: 8px;
    }

    .progress-hint {
      margin-top: 12px;
      font-size: 0.8rem;
      color: var(--muted-text);
      line-height: 1.5;
      margin-bottom: 0;
    }

    .form-panel {
      padding: 34px 34px 30px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .form-panel h3 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .form-panel .subtext {
      color: var(--muted-text);
      line-height: 1.7;
      margin-bottom: 28px;
    }

    .form-label {
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 8px;
    }

    .form-control,
    .form-select {
      border-radius: 18px;
      border: 1px solid var(--border-input);
      padding: 13px 16px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem var(--card-glow);
      background: var(--bg-surface);
    }

    textarea.form-control {
      resize: vertical;
      min-height: 120px;
    }

    .field-group {
      margin-bottom: 20px;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: 42px;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.3rem;
      }

      .profile-grid {
        grid-template-columns: 1fr;
      }

      .profile-sidebar {
        border-right: none;
        border-bottom: 1px solid rgba(216, 232, 240, 0.95);
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
      }

      .page-hero {
        border-radius: 24px;
        padding: 32px 0;
      }

      .page-hero h1 {
        font-size: 2rem;
      }

      .form-panel,
      .profile-sidebar {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentee/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu"
          aria-controls="menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentee/dashboard" class="nav-link">Dashboard</a></li>
            <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/mentee/feedback" class="nav-link">Feedback</a></li>
            <li class="nav-item"><a href="/mentee/profile" class="nav-link active">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="hero-badge">
          <i class="bi bi-person-badge-fill"></i>
          Mentee Profile
        </div>
        <h1>Shape a profile that helps mentors <span>guide you well.</span></h1>
        <p>Keep your goals, skills, and contact details up to date so the people supporting you can understand where you are and where you want to go.</p>
      </div>
    </section>

    <section class="container">
      <div class="profile-card">
        <form method="POST" action="/mentee/profile/update" enctype="multipart/form-data">
          <div class="profile-grid">
          <aside class="profile-sidebar">
            <label for="profilePictureInput" class="avatar-frame avatar-upload" aria-label="Choose profile picture">
              <div class="avatar">
                {{#if user.profilePicture}}
                  <img src="{{user.profilePicture}}" alt="{{user.name}}" id="profilePicturePreview" />
                {{else}}
                  <i class="bi bi-person" id="profilePicturePlaceholder"></i>
                  <img src="" alt="{{user.name}}" id="profilePicturePreview" style="display: none;" />
                {{/if}}
              </div>
            </label>
            <input id="profilePictureInput" type="file" name="profilePicture" class="visually-hidden-file-input" accept="image/*" />
            <div class="avatar-upload-note">Click the photo area to upload</div>
            <div class="profile-name">{{user.name}}</div>
            <div class="profile-email">{{user.email}}</div>
            <div class="info-chip"><i class="bi bi-mortarboard-fill"></i> Mentee Account</div>
            
            {{#if profileCompleteness}}
            <div class="profile-progress">
              <div class="progress-label">Profile Complete</div>
              <div class="circular-progress">
                <svg width="120" height="120">
                  <defs>
                    <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" style="stop-color:var(--secondary-color);stop-opacity:1" />
                      <stop offset="100%" style="stop-color:var(--accent-color);stop-opacity:1" />
                    </linearGradient>
                  </defs>
                  <circle class="progress-circle-bg" cx="60" cy="60" r="52"></circle>
                  <circle class="progress-circle-fill" cx="60" cy="60" r="52"
                    stroke-dasharray="326.73"
                    stroke-dashoffset="326.73"></circle>
                </svg>
                <div class="progress-percentage">{{profileCompleteness}}%</div>
              </div>
              {{#if profileIncomplete}}
                <p class="progress-hint">Fill in more details to improve your chances of matching with a great mentor.</p>
              {{/if}}
            </div>
            {{/if}}
            
            <p class="sidebar-note">A strong profile makes it easier to get useful mentorship, better context, and more relevant guidance.</p>
          </aside>

          <div class="form-panel">
            <div class="section-kicker"><i class="bi bi-pencil-square"></i> Update Details</div>
            <h3>Mentee information</h3>
            <p class="subtext">This keeps your public-facing information clear without changing any of your existing profile workflow.</p>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Full name</label>
                  <input type="text" class="form-control" value="{{user.name}}" disabled />
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Email Account</label>
                  <input type="email" class="form-control" value="{{user.email}}" disabled />
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phone" class="form-control" value="{{mentee.phone}}" placeholder="e.g +2547..." />
              </div>

              <div class="field-group">
                <label class="form-label">Education Level</label>
                <select name="education" class="form-select">
                  <option value="">Select Level</option>
                  <option value="High School" {{#ifEq mentee.educationLevel "High School"}}selected{{/ifEq}}>High School</option>
                  <option value="Undergraduate" {{#ifEq mentee.educationLevel "Undergraduate"}}selected{{/ifEq}}>Undergraduate</option>
                  <option value="Postgraduate" {{#ifEq mentee.educationLevel "Postgraduate"}}selected{{/ifEq}}>Postgraduate</option>
                  <option value="Professional" {{#ifEq mentee.educationLevel "Professional"}}selected{{/ifEq}}>Professional</option>
                </select>
              </div>

              <div class="field-group">
                <label class="form-label">Mentorship Goal</label>
                <textarea name="goal" class="form-control" rows="3" placeholder="Describe your goals..">{{mentee.goals}}</textarea>
              </div>

              <div class="field-group">
                <label class="form-label">Skills/Interests</label>
                <textarea name="skills" class="form-control" rows="3" placeholder="List your skills or interests....">{{mentee.skills}}</textarea>
              </div>

              <hr style="margin: 32px 0; border-color: rgba(216,232,240,0.7);">
              <div class="section-kicker"><i class="bi bi-sliders"></i> Optional Details</div>
              <p class="subtext" style="margin-bottom: 24px;">These fields help mentors better understand and connect with you (all optional).</p>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Current Role / Occupation</label>
                  <input type="text" name="currentRole" class="form-control" value="{{mentee.currentRole}}" placeholder="e.g. Student, Developer, Designer" />
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Institution / Company</label>
                  <input type="text" name="institution" class="form-control" value="{{mentee.institution}}" placeholder="e.g. USIU, Google, Freelance" />
                </div>
              </div>

              <div class="field-group">
                <label class="form-label">Location / Timezone</label>
                <input type="text" name="location" class="form-control" value="{{mentee.location}}" placeholder="e.g. Nairobi, Kenya (EAT)" />
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Learning Style</label>
                  <select name="learningStyle" class="form-select">
                    <option value="">Select style (optional)</option>
                    <option value="visual" {{#ifEq mentee.learningStyle "visual"}}selected{{/ifEq}}>Visual (diagrams, videos)</option>
                    <option value="hands-on" {{#ifEq mentee.learningStyle "hands-on"}}selected{{/ifEq}}>Hands-on (projects, practice)</option>
                    <option value="reading" {{#ifEq mentee.learningStyle "reading"}}selected{{/ifEq}}>Reading (articles, documentation)</option>
                    <option value="discussion" {{#ifEq mentee.learningStyle "discussion"}}selected{{/ifEq}}>Discussion (conversations, Q&A)</option>
                  </select>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Preferred Communication</label>
                  <select name="communicationPreference" class="form-select">
                    <option value="">Select preference (optional)</option>
                    <option value="video" {{#ifEq mentee.communicationPreference "video"}}selected{{/ifEq}}>Video calls</option>
                    <option value="chat" {{#ifEq mentee.communicationPreference "chat"}}selected{{/ifEq}}>Chat / Messaging</option>
                    <option value="email" {{#ifEq mentee.communicationPreference "email"}}selected{{/ifEq}}>Email</option>
                    <option value="in-person" {{#ifEq mentee.communicationPreference "in-person"}}selected{{/ifEq}}>In-person meetings</option>
                  </select>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 field-group">
                  <label class="form-label">Mentorship Experience</label>
                  <select name="mentorshipExperience" class="form-select">
                    <option value="">Select experience (optional)</option>
                    <option value="first-time" {{#ifEq mentee.mentorshipExperience "first-time"}}selected{{/ifEq}}>First-time mentee</option>
                    <option value="some" {{#ifEq mentee.mentorshipExperience "some"}}selected{{/ifEq}}>Some experience</option>
                    <option value="experienced" {{#ifEq mentee.mentorshipExperience "experienced"}}selected{{/ifEq}}>Experienced mentee</option>
                  </select>
                </div>
                <div class="col-md-6 field-group">
                  <label class="form-label">Preferred Session Frequency</label>
                  <select name="sessionFrequency" class="form-select">
                    <option value="">Select frequency (optional)</option>
                    <option value="weekly" {{#ifEq mentee.sessionFrequency "weekly"}}selected{{/ifEq}}>Weekly</option>
                    <option value="biweekly" {{#ifEq mentee.sessionFrequency "biweekly"}}selected{{/ifEq}}>Bi-weekly</option>
                    <option value="monthly" {{#ifEq mentee.sessionFrequency "monthly"}}selected{{/ifEq}}>Monthly</option>
                    <option value="as-needed" {{#ifEq mentee.sessionFrequency "as-needed"}}selected{{/ifEq}}>As-needed</option>
                  </select>
                </div>
              </div>

              <div class="row" style="margin-top: 16px;">
                <div class="col-md-6 field-group">
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="isProfilePublic" name="isProfilePublic" value="true" {{#if mentee.isProfilePublic}}checked{{/if}} style="width: 3em; height: 1.5em; margin-right: 12px;">
                    <label class="form-check-label" for="isProfilePublic" style="font-weight: 600; color: var(--primary-color);">
                      Profile visible to mentors
                    </label>
                    <div style="font-size: 0.85rem; color: var(--muted-text); margin-top: 4px;">
                      Allow mentors to find and view your profile
                    </div>
                  </div>
                </div>
                <div class="col-md-6 field-group">
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="openToMentorship" name="openToMentorship" value="true" {{#if mentee.openToMentorship}}checked{{/if}} style="width: 3em; height: 1.5em; margin-right: 12px;">
                    <label class="form-check-label" for="openToMentorship" style="font-weight: 600; color: var(--primary-color);">
                      Open to mentorship
                    </label>
                    <div style="font-size: 0.85rem; color: var(--muted-text); margin-top: 4px;">
                      Signal that you're actively seeking a mentor
                    </div>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-save px-4 py-3">Save Profile</button>
          </div>
          </div>
        </form>
      </div>
    </section>

    <footer>
      &copy; 2025 MentorLink. All rights reserved.
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Animate circular progress bar
    document.addEventListener('DOMContentLoaded', function() {
      const progressFill = document.querySelector('.progress-circle-fill');
      const percentageText = document.querySelector('.progress-percentage');
      
      if (progressFill && percentageText) {
        const percentage = parseInt(percentageText.textContent);
        const circumference = 2 * Math.PI * 52; // radius = 52
        const offset = circumference - (percentage / 100) * circumference;
        
        // Animate the progress bar
        setTimeout(() => {
          progressFill.style.strokeDashoffset = offset;
        }, 300);
      }
    });

    // Profile picture preview
    const menteeProfileInput = document.getElementById('profilePictureInput');
    const menteeProfilePreview = document.getElementById('profilePicturePreview');
    const menteeProfilePlaceholder = document.getElementById('profilePicturePlaceholder');

    if (menteeProfileInput && menteeProfilePreview) {
      menteeProfileInput.addEventListener('change', (event) => {
        const [file] = event.target.files;

        if (!file) {
          return;
        }

        menteeProfilePreview.src = URL.createObjectURL(file);
        menteeProfilePreview.style.display = 'block';

        if (menteeProfilePlaceholder) {
          menteeProfilePlaceholder.style.display = 'none';
        }
      });
    }
  </script>
  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
</body>
</html>