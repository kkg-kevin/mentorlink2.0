<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MentorLink | {{mentor.user.name}} - Mentor Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.12), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.12), transparent 28%),
        var(--bg-base);
      color: var(--text-primary);
      min-height: 100vh;
    }

    .navbar {
      background: var(--navbar-bg) !important;
      border-bottom: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
    }

    .profile-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .profile-header {
      background: var(--bg-surface-alt);
      border-radius: 20px;
      padding: 2rem;
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
      margin-bottom: 2rem;
    }

    .profile-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--primary-color);
      box-shadow: 0 8px 20px rgba(0, 119, 182, 0.2);
    }

    .profile-section {
      background: var(--bg-surface-alt);
      border-radius: 15px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
    }

    .section-title {
      color: var(--primary-color);
      font-weight: 600;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .badge-custom {
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 500;
      margin: 0.25rem;
    }

    .rating-stars {
      color: #ffc107;
    }

    .back-button {
      background: var(--primary-color);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.3s ease;
    }

    .back-button:hover {
      background: #005f87;
      color: white;
      transform: translateY(-2px);
    }

    .request-button {
      background: var(--secondary-color);
      color: white;
      border: none;
      padding: 0.75rem 2rem;
      border-radius: 10px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.3s ease;
    }

    .request-button:hover {
      background: #238d7f;
      color: white;
      transform: translateY(-2px);
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .info-item {
      padding: 0.75rem;
      background: var(--light-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }

    .info-label {
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 0.25rem;
    }

    .review-item {
      padding: 1rem;
      border-left: 4px solid var(--primary-color);
      background: var(--light-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      margin-bottom: 1rem;
    }

    .review-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .review-author {
      font-weight: 600;
      color: var(--primary-color);
    }

    .review-date {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    @media (max-width: 768px) {
      .profile-container {
        margin: 1rem auto;
        padding: 0 0.5rem;
      }
      
      .profile-header {
        padding: 1.5rem;
      }
      
      .profile-avatar {
        width: 100px;
        height: 100px;
      }
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid px-3 px-lg-4 px-xl-5">
      <a class="navbar-brand fw-bold" href="/mentee/dashboard">MentorLink</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="modulesDropdown" role="button" data-bs-toggle="dropdown">
              Modules
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/mentee/dashboard">Dashboard</a></li>
              <li><a class="dropdown-item" href="/mentee/sessions">Sessions</a></li>
              <li><a class="dropdown-item" href="/mentee/feedback">Feedback</a></li>
            </ul>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i> {{user.name}}
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/mentee/profile">Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="profile-container">
    <!-- Back Button -->
    <a href="/mentee/dashboard" class="back-button mb-4">
      <i class="bi bi-arrow-left"></i>
      Back to Dashboard
    </a>

    <!-- Profile Header -->
    <div class="profile-header">
      <div class="row align-items-center">
        <div class="col-md-3 text-center">
          {{#if mentor.user.profilePicture}}
            <img src="{{mentor.user.profilePicture}}" alt="{{mentor.user.name}}" class="profile-avatar">
          {{else}}
            <div class="profile-avatar d-flex align-items-center justify-content-center bg-primary text-white">
              <i class="bi bi-person fs-1"></i>
            </div>
          {{/if}}
        </div>
        <div class="col-md-6">
          <h2 class="mb-2">{{mentor.user.name}}</h2>
          <p class="text-muted mb-3">{{mentor.expertise}}</p>
          
          <!-- Rating -->
          <div class="d-flex align-items-center mb-3">
            <div class="rating-stars me-2">
              {{{renderStarIcons mentorRating.avgRating}}}
            </div>
            <span class="text-muted">({{mentorRating.ratingCount}} reviews)</span>
          </div>

          <!-- Availability -->
          <div class="mb-3">
            <span class="badge bg-success badge-custom">
              <i class="bi bi-check-circle me-1"></i>{{mentor.availability}}
            </span>
            {{#if mentor.openToNewMentees}}
              <span class="badge bg-primary badge-custom">
                <i class="bi bi-person-plus me-1"></i>Open to New Mentees
              </span>
            {{/if}}
          </div>

          <!-- Action Buttons -->
          <div class="d-flex gap-2">
            <button type="button" class="request-button" data-bs-toggle="modal" data-bs-target="#requestModal">
              <i class="bi bi-calendar-check"></i>
              Request Session
            </button>
          </div>
        </div>
        <div class="col-md-3 text-center">
          <div class="info-item">
            <div class="info-label">Experience</div>
            <div>{{mentor.experienceYears}} years</div>
          </div>
          {{#if mentor.mentorshipCapacity}}
            <div class="info-item mt-2">
              <div class="info-label">Capacity</div>
              <div>{{mentor.mentorshipCapacity}} mentees</div>
            </div>
          {{/if}}
        </div>
      </div>
    </div>

    <!-- Professional Details Section -->
    <div class="profile-section">
      <h5 class="section-title">
        <i class="bi bi-briefcase"></i>
        Professional Details
      </h5>
      <div class="info-grid">
        {{#if mentor.company}}
          <div class="info-item">
            <div class="info-label">Company</div>
            <div>{{mentor.company}}</div>
          </div>
        {{/if}}
        {{#if mentor.position}}
          <div class="info-item">
            <div class="info-label">Position</div>
            <div>{{mentor.position}}</div>
          </div>
        {{/if}}
        {{#if mentor.industry}}
          <div class="info-item">
            <div class="info-label">Industry</div>
            <div>{{mentor.industry}}</div>
          </div>
        {{/if}}
        {{#if mentor.specialization}}
          <div class="info-item">
            <div class="info-label">Specialization</div>
            <div>{{mentor.specialization}}</div>
          </div>
        {{/if}}
        {{#if mentor.phone}}
          <div class="info-item">
            <div class="info-label">Phone</div>
            <div>{{mentor.phone}}</div>
          </div>
        {{/if}}
        {{#if mentor.responseTime}}
          <div class="info-item">
            <div class="info-label">Response Time</div>
            <div>{{mentor.responseTime}}</div>
          </div>
        {{/if}}
      </div>
      
      <!-- Links -->
      <div class="mt-3">
        {{#if mentor.linkedinProfile}}
          <a href="{{mentor.linkedinProfile}}" target="_blank" class="btn btn-outline-primary btn-sm me-2">
            <i class="bi bi-linkedin"></i> LinkedIn Profile
          </a>
        {{/if}}
        {{#if mentor.website}}
          <a href="{{mentor.website}}" target="_blank" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-globe"></i> Website
          </a>
        {{/if}}
      </div>
    </div>

    <!-- Expertise Areas Section -->
    <div class="profile-section">
      <h5 class="section-title">
        <i class="bi bi-star"></i>
        Expertise Areas
      </h5>
      
      {{#if mentor.industries}}
        <div class="mb-3">
          <h6 class="text-muted">Industries</h6>
          <div>
            {{#each mentor.industries}}
              <span class="badge bg-light text-dark badge-custom">{{this}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if mentor.specialties}}
        <div class="mb-3">
          <h6 class="text-muted">Specialties</h6>
          <div>
            {{#each mentor.specialties}}
              <span class="badge bg-primary badge-custom">{{this}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if mentor.languages}}
        <div>
          <h6 class="text-muted">Languages</h6>
          <div>
            {{#each mentor.languages}}
              <span class="badge bg-info text-white badge-custom">{{this}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}
    </div>

    <!-- Mentorship Preferences Section -->
    <div class="profile-section">
      <h5 class="section-title">
        <i class="bi bi-gear"></i>
        Mentorship Preferences
      </h5>
      <div class="info-grid">
        {{#if mentor.menteeLevel}}
          <div class="info-item">
            <div class="info-label">Preferred Mentee Level</div>
            <div>{{mentor.menteeLevel}}</div>
          </div>
        {{/if}}
        {{#if mentor.sessionFormat}}
          <div class="info-item">
            <div class="info-label">Session Format</div>
            <div>{{mentor.sessionFormat}}</div>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- Bio Section -->
    {{#if mentor.bio}}
      <div class="profile-section">
        <h5 class="section-title">
          <i class="bi bi-person"></i>
          About
        </h5>
        <p class="text-muted">{{mentor.bio}}</p>
      </div>
    {{/if}}

    <!-- Reviews Section -->
    {{#if hasRecentReviews}}
      <div class="profile-section">
        <h5 class="section-title">
          <i class="bi bi-chat-quote"></i>
          Recent Reviews
        </h5>
        {{#each recentReviews}}
          <div class="review-item">
            <div class="review-header">
              <div class="review-author">{{from.name}}</div>
              <div class="review-date">{{formatDate createdAt}}</div>
            </div>
            <div class="rating-stars mb-2">
              {{{renderStarIcons rating}}}
            </div>
            <p class="mb-0">{{comment}}</p>
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>

  <!-- Request Session Modal -->
  <div class="modal fade" id="requestModal" tabindex="-1" aria-labelledby="requestModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="requestModalLabel">Request Session with {{mentor.user.name}}</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form method="POST" action="/mentee/session/request">
          <div class="modal-body">
            <input type="hidden" name="mentorId" value="{{mentor._id}}">
            
            <!-- Mentor Info -->
            <div class="mb-4 p-3 bg-light rounded">
              <h6 class="mb-2">About {{mentor.user.name}}</h6>
              <div class="row">
                {{#if mentor.company}}
                  <div class="col-md-6 mb-2">
                    <strong>Company:</strong> {{mentor.company}}
                  </div>
                {{/if}}
                {{#if mentor.position}}
                  <div class="col-md-6 mb-2">
                    <strong>Position:</strong> {{mentor.position}}
                  </div>
                {{/if}}
                {{#if mentor.sessionFormat}}
                  <div class="col-md-6 mb-2">
                    <strong>Format:</strong> {{mentor.sessionFormat}}
                  </div>
                {{/if}}
                {{#if mentor.responseTime}}
                  <div class="col-md-6 mb-2">
                    <strong>Response Time:</strong> {{mentor.responseTime}}
                  </div>
                {{/if}}
              </div>
            </div>

            <!-- Form Fields -->
            <div class="mb-3">
              <label for="scheduledAt" class="form-label">
                <i class="bi bi-calendar-event me-2"></i>Select Date & Time
              </label>
              <input type="datetime-local" class="form-control" id="scheduledAt" name="scheduledAt" required>
            </div>
            <div class="mb-0">
              <label for="notes" class="form-label">
                <i class="bi bi-chat-left-text me-2"></i>Message (Optional)
              </label>
              <textarea class="form-control" id="notes" name="notes" rows="3" 
                placeholder="Tell {{mentor.user.name}} what you'd like to learn..."></textarea>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Send Request</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode"></button>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Set minimum datetime to now
    document.addEventListener('DOMContentLoaded', function() {
      const now = new Date();
      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
      const minDateTime = now.toISOString().slice(0, 16);
      const datetimeInput = document.getElementById('scheduledAt');
      if (datetimeInput) {
        datetimeInput.min = minDateTime;
      }
    });
  </script>
</body>
</html>
