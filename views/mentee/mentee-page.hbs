  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const now = new Date();
      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
      const minDateTime = now.toISOString().slice(0, 16);
      document.querySelectorAll('input[type="datetime-local"]').forEach(input => {
        input.min = minDateTime;
      });

      updateResultsCount();
    });

    function filterResults() {
      const searchInput = document.getElementById('searchInput').value.toLowerCase();
      const typeFilter = document.getElementById('typeFilter').value.toLowerCase();
      const availabilityFilter = document.getElementById('availabilityFilter').value.toLowerCase();

      const mentorCards = document.querySelectorAll('.mentor-card');
      const organizationCards = document.querySelectorAll('.organization-card');

      let visibleCount = 0;

      mentorCards.forEach(card => {
        const name = (card.dataset.name || '').toLowerCase();
        const expertise = (card.dataset.expertise || '').toLowerCase();
        const availability = (card.dataset.availability || '').toLowerCase();
        const bio = (card.dataset.bio || '').toLowerCase();
        const type = card.dataset.type;

        let show = true;

        if (searchInput && !name.includes(searchInput) && !expertise.includes(searchInput) && !bio.includes(searchInput)) {
          show = false;
        }

        if (typeFilter && type !== typeFilter) {
          show = false;
        }

        if (availabilityFilter && !availability.includes(availabilityFilter)) {
          show = false;
        }

        card.style.display = show ? 'block' : 'none';
        if (show) visibleCount++;
      });

      organizationCards.forEach(card => {
        const name = (card.dataset.name || '').toLowerCase();
        const expertise = (card.dataset.expertise || '').toLowerCase();
        const description = (card.dataset.description || '').toLowerCase();
        const type = card.dataset.type;

        let show = true;

        if (searchInput && !name.includes(searchInput) && !expertise.includes(searchInput) && !description.includes(searchInput)) {
          show = false;
        }

        if (typeFilter && type !== typeFilter) {
          show = false;
        }

        card.style.display = show ? 'block' : 'none';
        if (show) visibleCount++;
      });

      const companiesHeader = document.getElementById('companiesHeader');
      const visibleOrgs = Array.from(organizationCards).filter(card => card.style.display !== 'none').length;
      if (companiesHeader) {
        companiesHeader.style.display = visibleOrgs > 0 ? 'block' : 'none';
      }

      updateResultsCount(visibleCount);
      showNoResultsMessage(visibleCount);
    }

    function resetFilters() {
      document.getElementById('searchInput').value = '';
      document.getElementById('typeFilter').value = '';
      document.getElementById('availabilityFilter').value = '';
      filterResults();
    }

    function updateResultsCount(count) {
      const resultsCount = document.getElementById('resultsCount');
      const totalMentors = document.querySelectorAll('.mentor-card').length;
      const totalOrgs = document.querySelectorAll('.organization-card').length;
      const total = totalMentors + totalOrgs;

      if (count === undefined) {
        count = total;
      }

      if (count > 0) {
        resultsCount.innerHTML = `<i class="bi bi-funnel me-2"></i>Showing ${count} of ${total} results`;
        resultsCount.style.color = '#0077b6';
        resultsCount.style.fontWeight = '500';
      } else if (total > 0) {
        resultsCount.innerHTML = '<i class="bi bi-search me-2"></i>No results match your filters. Try adjusting your search.';
        resultsCount.style.color = '#dc3545';
        resultsCount.style.fontWeight = '500';
      } else {
        resultsCount.innerHTML = '';
      }
    }

    function showNoResultsMessage(visibleCount) {
      const existingMessages = document.querySelectorAll('.no-results-message');
      existingMessages.forEach(msg => msg.remove());

      if (visibleCount === 0) {
        const mentorsContainer = document.getElementById('mentorsContainer');
        const noResultsDiv = document.createElement('div');
        noResultsDiv.className = 'col-12 no-results-message';
        noResultsDiv.innerHTML = `
          <div class="empty-state">
            <i class="bi bi-search"></i>
            <h5>No Results Found</h5>
            <p>We couldn't find any mentors or organizations matching your criteria.</p>
            <button onclick="resetFilters()" class="btn btn-search mt-3">Clear Filters</button>
          </div>
        `;
        mentorsContainer.appendChild(noResultsDiv);
      }
    }
  </script>
  <button id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">
    <i class="bi bi-moon-fill"></i>
  </button>
</body>
</html>
