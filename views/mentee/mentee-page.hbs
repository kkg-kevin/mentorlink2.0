<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MentorLink | Mentee Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme.js"></script>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      color: var(--text-primary);
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.10), transparent 24%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.10), transparent 28%),
        var(--bg-base);
      min-height: 100vh;
    }

    .page-shell {
      width: 100%;
      max-width: none;
      padding-bottom: 36px;
    }

    .page-shell .container {
      max-width: min(1820px, calc(100vw - 24px));
    }

    .navbar {
      margin: 18px auto 0;
      background: var(--navbar-bg);
      border: 1px solid var(--border-color);
      box-shadow: var(--navbar-shadow);
      backdrop-filter: blur(10px);
      border-radius: 22px;
      padding: 14px 0;
    }

    .navbar-brand {
      font-weight: 700;
      color: var(--secondary-color) !important;
      display: flex;
      align-items: center;
    }

    .navbar-brand img {
      margin-right: 10px;
      border-radius: 14px !important;
      box-shadow: 0 8px 18px rgba(0, 48, 73, 0.12);
    }

    .nav-link {
      color: var(--text-primary) !important;
      font-weight: 500;
      margin: 0 6px;
      padding: 8px 14px !important;
      border-radius: 999px;
      transition: all 0.25s ease;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--secondary-color) !important;
      background: var(--bg-chip);
    }

    .btn-logout,
    .btn-search,
    .btn-available,
    .btn-request,
    .btn-modal-primary,
    .btn-modal-secondary {
      border-radius: 999px;
      font-weight: 600;
      transition: all 0.25s ease;
      border: none;
    }

    .btn-logout:hover,
    .btn-search:hover,
    .btn-available:hover,
    .btn-request:hover,
    .btn-modal-primary:hover,
    .btn-modal-secondary:hover {
      transform: translateY(-2px);
    }

    .btn-logout,
    .btn-search,
    .btn-available,
    .btn-modal-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 22px rgba(0, 119, 182, 0.18);
    }

    .btn-request {
      color: var(--primary-color);
      background: linear-gradient(135deg, rgba(42, 157, 143, 0.14), rgba(0, 119, 182, 0.10));
      box-shadow: 0 10px 18px rgba(0, 48, 73, 0.08);
    }

    .btn-modal-secondary {
      color: var(--primary-color);
      background: var(--bg-surface-alt);
      border: 1px solid var(--surface-border);
    }

    .page-hero {
      margin-top: 26px;
      padding: 42px 0;
      position: relative;
      overflow: hidden;
      border-radius: 30px;
      background: var(--bg-hero);
      border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow);
    }

    .page-hero::before {
      content: '';
      position: absolute;
      width: 260px;
      height: 260px;
      right: -70px;
      top: -80px;
      background: rgba(0, 119, 182, 0.08);
      border-radius: 34px;
      transform: rotate(16deg);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-grid {
      align-items: center;
      gap: 24px 0;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 999px;
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      padding: 10px 16px;
      color: var(--muted-text);
      font-size: 0.92rem;
      box-shadow: 0 10px 20px rgba(0, 48, 73, 0.06);
    }

    .page-hero h1 {
      margin: 16px 0 14px;
      font-weight: 700;
      font-size: 3rem;
      line-height: 1.08;
    }

    .page-hero h1 span {
      color: var(--secondary-color);
    }

    .hero-copy p {
      color: var(--muted-text);
      line-height: 1.8;
      font-size: 1.02rem;
      margin-bottom: 0;
      max-width: 920px;
    }

    .hero-aside {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      padding: 24px;
      box-shadow: var(--card-shadow);
    }

    .hero-aside h5 {
      font-weight: 700;
      margin-bottom: 14px;
    }

    .hero-aside-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .hero-aside-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: var(--muted-text);
      margin-bottom: 12px;
    }

    .hero-aside-list i {
      color: var(--accent-color);
      margin-top: 2px;
    }

    .section-card,
    .directory-card,
    .empty-state {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 26px;
      box-shadow: var(--card-shadow);
    }

    .announcement-card {
      background: var(--bg-surface-alt);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      box-shadow: var(--card-shadow);
      padding: 22px;
      margin-top: 20px;
    }

    .announcement-card h4 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .announcement-card p {
      color: var(--muted-text);
      margin-bottom: 0;
      line-height: 1.7;
    }

    .filters-wrap {
      margin-top: 24px;
      padding: 20px 22px;
    }

    .filters-top {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      margin-bottom: 14px;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 119, 182, 0.08);
      color: var(--secondary-color);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .section-title {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .section-description {
      color: var(--muted-text);
      margin: 0;
      max-width: 980px;
      line-height: 1.7;
    }

    .filters-wrap .section-kicker {
      padding: 6px 10px;
      font-size: 0.78rem;
      margin-bottom: 10px;
    }

    .filters-wrap .section-title {
      font-size: 1.55rem;
      margin-bottom: 6px;
    }

    .filters-wrap .section-description {
      font-size: 0.95rem;
      line-height: 1.55;
      max-width: 860px;
    }

    .filters-wrap .row {
      --bs-gutter-y: 0.7rem;
      --bs-gutter-x: 0.9rem;
    }

    .filters .form-control,
    .filters .form-select,
    .modal .form-control,
    .modal textarea {
      border-radius: 14px;
      border: 1px solid var(--border-input);
      padding: 10px 14px;
      background: var(--bg-input);
      color: var(--text-primary);
      transition: all 0.25s ease;
    }

    .filters .form-control:focus,
    .filters .form-select:focus,
    .modal .form-control:focus,
    .modal textarea:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem var(--card-glow);
      background: var(--bg-surface);
    }

    #resultsCount {
      color: var(--secondary-color);
      font-weight: 500;
    }

    .filters-wrap #resultsCount {
      font-size: 0.92rem;
      margin-top: 12px;
    }

    .directory-section {
      margin-top: 28px;
    }

    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 16px;
      margin-bottom: 18px;
    }

    .section-heading p {
      color: var(--muted-text);
      margin: 8px 0 0;
    }

    .directory-card {
      height: 100%;
      padding: 28px 24px 24px;
      transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
      position: relative;
      overflow: hidden;
    }

    .directory-card::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--secondary-color), var(--accent-color));
      opacity: 0.9;
    }

    .directory-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 22px 40px rgba(0, 48, 73, 0.12);
      border-color: var(--border-input);
    }

    .profile-frame {
      width: 104px;
      height: 104px;
      border-radius: 28px;
      padding: 8px;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.14), rgba(42, 157, 143, 0.14));
      margin: 4px auto 18px;
      box-shadow: 0 14px 28px rgba(0, 48, 73, 0.10);
    }

    .profile-frame img {
      width: 100%;
      height: 100%;
      border-radius: 22px;
      object-fit: cover;
      object-position: center;
      display: block;
      background: var(--bg-surface);
    }

    .card-meta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 12px;
      border-radius: 999px;
      background: var(--bg-chip);
      color: var(--secondary-color);
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .card-title {
      font-weight: 700;
      margin-bottom: 10px;
    }

    .directory-card p {
      color: var(--muted-text);
      line-height: 1.7;
      margin-bottom: 10px;
    }

    .detail-line strong {
      color: var(--primary-color);
      margin-right: 4px;
    }

    .card-actions {
      display: flex;
      gap: 10px;
      margin-top: 18px;
    }

    .mentor-rating {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      background: var(--bg-surface-soft);
      border: 1px solid var(--border-color);
    }

    .mentor-rating-value {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      font-weight: 700;
      color: var(--primary-color);
      margin-bottom: 4px;
    }

    .mentor-rating-stars {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 1.05rem;
      color: #c5cfda;
    }

    .mentor-rating-stars .is-active {
      color: #f4b400;
    }

    .mentor-rating-meta {
      color: var(--muted-text);
      font-size: 0.88rem;
      margin-bottom: 0;
    }

    .card-actions > * {
      flex: 1;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
    }

    .empty-state {
      padding: 38px 24px;
      text-align: center;
    }

    .empty-state i {
      font-size: 2.4rem;
      color: var(--secondary-color);
      margin-bottom: 14px;
      display: inline-block;
    }

    .empty-state h5 {
      font-weight: 700;
      margin-bottom: 8px;
    }

    .empty-state p {
      color: var(--muted-text);
      margin: 0;
    }

    .modal-content {
      border-radius: 26px;
      border: 1px solid var(--border-color);
      box-shadow: 0 22px 50px rgba(0, 48, 73, 0.15);
      overflow: hidden;
      background: var(--bg-surface);
    }

    .modal-header {
      border-bottom: none;
      padding: 22px 24px 12px;
      background: var(--bg-chip);
    }

    .modal-title {
      font-weight: 700;
      color: var(--text-primary);
    }

    .modal-body {
      padding: 24px;
    }

    .modal-footer {
      border-top: none;
      padding: 0 24px 24px;
      gap: 10px;
    }

    .form-label {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    footer {
      background: var(--navbar-bg);
      border-top: 1px solid var(--border-color);
      text-align: center;
      padding: 20px 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      margin-top: 42px;
    }

    @media (max-width: 992px) {
      .page-hero h1 {
        font-size: 2.5rem;
      }
    }

    @media (max-width: 768px) {
      .page-shell .container {
        max-width: calc(100vw - 12px);
      }

      .navbar {
        border-radius: 18px;
      }

      .page-hero {
        padding: 34px 0;
        border-radius: 24px;
      }

      .page-hero h1 {
        font-size: 2.1rem;
      }

      .filters-wrap,
      .directory-card {
        padding-left: 18px;
        padding-right: 18px;
      }

      .filters-top,
      .section-heading {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 576px) {
      .page-hero h1 {
        font-size: 1.9rem;
      }

      .card-actions {
        flex-direction: column;
      }

      .btn-logout,
      .btn-search,
      .btn-available,
      .btn-request,
      .btn-modal-primary,
      .btn-modal-secondary {
        width: 100%;
      }
    }

    /* ── Full Profile Modal ── */
    .fp-hero {
      background: var(--bg-progress);
      border-bottom: 1px solid var(--surface-border);
    }
    .fp-hero-inner {
      padding: 2rem 2rem 1.5rem;
    }
    .fp-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      border: 5px solid var(--bg-surface);
      box-shadow: 0 10px 28px rgba(0,48,73,0.14);
      margin-bottom: 1rem;
    }
    .fp-avatar-wrap {
      display: inline-block;
    }
    .fp-name {
      font-weight: 700;
      color: var(--primary-color);
      margin-bottom: 4px;
    }
    .fp-role {
      color: var(--muted-text);
      font-size: 1rem;
      margin-bottom: 1rem;
    }
    .fp-rating {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-chip);
      border: 1px solid var(--border-color);
      border-radius: 999px;
      padding: 6px 14px;
      margin-bottom: 1rem;
    }
    .fp-rating-text {
      font-size: 0.88rem;
      color: var(--muted-text);
    }
    .fp-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-bottom: 1.25rem;
    }
    .fp-badge {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.84rem;
      font-weight: 600;
    }
    .fp-badge-green  { background: rgba(40,167,69,0.12);  color: #1a7a32; border: 1px solid rgba(40,167,69,0.25); }
    .fp-badge-blue   { background: rgba(0,119,182,0.10);  color: var(--secondary-color); border: 1px solid rgba(0,119,182,0.22); }
    .fp-badge-amber  { background: rgba(255,193,7,0.14);  color: #856404; border: 1px solid rgba(255,193,7,0.28); }
    .fp-badge-teal   { background: rgba(42,157,143,0.12); color: #1a6b60; border: 1px solid rgba(42,157,143,0.25); }
    .fp-body {
      padding: 0 1.5rem 1.5rem;
    }
    .fp-section {
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--surface-border);
    }
    .fp-section:last-child {
      border-bottom: none;
    }
    .fp-section-title {
      font-weight: 700;
      color: var(--secondary-color);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .fp-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }
    .fp-item {
      background: var(--surface-soft);
      border: 1px solid var(--surface-border);
      border-radius: 14px;
      padding: 12px 14px;
    }
    .fp-label {
      display: block;
      font-size: 0.76rem;
      font-weight: 600;
      color: var(--muted-text);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }
    .fp-value {
      font-weight: 600;
      color: var(--primary-color);
      font-size: 0.92rem;
    }
    .fp-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .fp-tag {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.84rem;
      font-weight: 500;
    }
    .fp-tag-muted { background: var(--bg-chip); color: var(--primary-color); }
    .fp-tag-blue  { background: rgba(0,119,182,0.10); color: var(--secondary-color); border: 1px solid rgba(0,119,182,0.18); }
    .fp-tag-teal  { background: rgba(42,157,143,0.10); color: #1a6b60; border: 1px solid rgba(42,157,143,0.20); }
    .fp-bio {
      color: var(--muted-text);
      line-height: 1.8;
      margin: 0;
    }
    .fp-link-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 16px;
      border-radius: 999px;
      font-size: 0.84rem;
      font-weight: 600;
      text-decoration: none;
      margin-top: 12px;
      margin-right: 8px;
      transition: opacity 0.2s;
    }
    .fp-link-btn:hover { opacity: 0.82; }
    .fp-link-linkedin { background: #0077b5; color: #fff; }
    .fp-link-web      { background: var(--accent-color); color: #fff; }
  </style>
</head>
<body>
  <div class="page-shell">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <div class="container-fluid px-3 px-lg-4 px-xl-5">
        <a class="navbar-brand d-flex align-items-center" href="/mentee/dashboard">
          <img src="/images/Logo 1.png" alt="MentorLink Logo" width="40" height="40" class="me-2">
          MentorLink
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu"
          aria-controls="menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="menu">
          <ul class="navbar-nav align-items-lg-center mb-2 mb-lg-0">
            <li class="nav-item"><a href="/mentee/dashboard" class="nav-link active">Dashboard</a></li>
            <li class="nav-item"><a href="/mentee/sessions" class="nav-link">Sessions</a></li>
            <li class="nav-item"><a href="/mentee/feedback" class="nav-link">Feedback</a></li>
            <li class="nav-item"><a href="/mentee/profile" class="nav-link">Profile</a></li>
          </ul>
          <form method="POST" action="/auth/logout" style="display:inline;">
            <button type="submit" class="btn btn-logout ms-lg-3 mt-2 mt-lg-0">Log out</button>
          </form>
        </div>
      </div>
    </nav>

    <section class="container page-hero">
      <div class="hero-content">
        <div class="row hero-grid">
          <div class="col-lg-8 hero-copy">
            <div class="hero-badge">
              <i class="bi bi-mortarboard-fill"></i>
              Mentee Workspace
            </div>
            <h1>Find the <span>right guidance</span> and start strong.</h1>
            <p>Welcome, {{#if user}}{{user.name}}{{else}}Mentee{{/if}}. Explore mentors and partner organizations, filter by what matters to you, and start conversations that move your goals forward.</p>
          </div>
          <div class="col-lg-4">
            <div class="hero-aside">
              <h5>What you can do here</h5>
              <ul class="hero-aside-list">
                <li><i class="bi bi-search-heart-fill"></i><span>Browse mentors by expertise, bio, and availability.</span></li>
                <li><i class="bi bi-buildings-fill"></i><span>Join structured organization programs that fit your interests.</span></li>
                <li><i class="bi bi-calendar-check-fill"></i><span>Request sessions directly without changing your current flow.</span></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    {{#if activeAnnouncement}}
    <section class="container">
      <div class="announcement-card">
        <div class="section-kicker"><i class="bi bi-megaphone"></i> Announcement</div>
        <h4>{{activeAnnouncement.title}}</h4>
        <p>{{activeAnnouncement.message}}</p>
      </div>
    </section>
    {{/if}}

    <section class="container">
      <div class="section-card filters-wrap filters">
        <div class="filters-top">
          <div>
            <div class="section-kicker"><i class="bi bi-sliders"></i> Discovery Filters</div>
            <h3 class="section-title">Search mentors and organizations</h3>
            <p class="section-description">Narrow the directory by keyword, type, or availability to quickly find the right mentorship opportunity.</p>
          </div>
        </div>
        <form class="row g-3 align-items-center" id="searchForm" onsubmit="return false;">
          <div class="col-md-4 col-sm-6">
            <input type="text" id="searchInput" class="form-control" placeholder="Search by name, expertise, or keyword..." oninput="filterResults()">
          </div>
          <div class="col-md-3 col-sm-6">
            <select id="typeFilter" class="form-select" onchange="filterResults()">
              <option value="">All Types...</option>
              <option value="mentor">Mentors Only</option>
              <option value="organization">Organizations Only</option>
            </select>
          </div>
          <div class="col-md-3 col-sm-6">
            <select id="availabilityFilter" class="form-select" onchange="filterResults()">
              <option value="">All Availability...</option>
              <option value="Available">Available</option>
              <option value="Busy">Busy</option>
            </select>
          </div>
          <div class="col-md-2 d-grid">
            <button type="button" class="btn btn-search" onclick="resetFilters()">Reset</button>
          </div>
        </form>
        <div id="resultsCount" class="mt-3 text-center"></div>
      </div>
