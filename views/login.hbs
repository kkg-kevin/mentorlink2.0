<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - MentorLink</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #003049;
      --secondary-color: #0077b6;
      --accent-color: #2a9d8f;
      --light-color: #e8f6fc;
      --warm-color: #f4d35e;
      --card-glow: rgba(0, 119, 182, 0.16);
    }
    body {
      font-family: 'Poppins', sans-serif;
      background:
        radial-gradient(circle at top right, rgba(42, 157, 143, 0.18), transparent 30%),
        radial-gradient(circle at bottom left, rgba(0, 119, 182, 0.16), transparent 32%),
        linear-gradient(135deg, var(--light-color) 0%, #c8ebfb 100%);
      min-height: 100vh;
    }
    .auth-shell {
      max-width: 960px;
    }
    .auth-card {
      border: none;
      border-radius: 28px;
      box-shadow: 0 18px 50px rgba(0, 48, 73, 0.12);
      overflow: hidden;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(10px);
    }
    .intro-panel {
      background: linear-gradient(160deg, #003049 0%, #005f89 52%, #2a9d8f 100%);
      color: white;
      padding: 42px 34px;
      height: 100%;
      position: relative;
      overflow: hidden;
    }
    .intro-panel::before {
      content: '';
      position: absolute;
      width: 220px;
      height: 220px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 28px;
      top: -70px;
      right: -50px;
      transform: rotate(18deg);
    }
    .intro-panel::after {
      content: '';
      position: absolute;
      width: 180px;
      height: 180px;
      background: rgba(244, 211, 94, 0.12);
      border-radius: 50%;
      bottom: -60px;
      left: -30px;
    }
    .intro-panel > * {
      position: relative;
      z-index: 1;
    }
    .panel-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 0.82rem;
      font-weight: 600;
      background: rgba(255, 255, 255, 0.14);
      margin-bottom: 18px;
    }
    .panel-copy {
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.96rem;
      line-height: 1.7;
    }
    .benefit-list {
      margin-top: 26px;
      padding-left: 0;
      list-style: none;
    }
    .benefit-list li {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 14px;
      color: rgba(255, 255, 255, 0.88);
      font-size: 0.94rem;
    }
    .benefit-list i {
      color: var(--warm-color);
      margin-top: 2px;
    }
    .form-panel {
      padding: 38px 34px;
    }
    .brand-mark {
      max-width: 84px;
      border-radius: 20px;
      box-shadow: 0 10px 24px rgba(0, 48, 73, 0.12);
    }
    .section-title {
      color: var(--primary-color);
      font-weight: 700;
      margin-bottom: 8px;
    }
    .section-copy {
      color: #5d6a73;
      font-size: 0.95rem;
    }
    .form-label {
      color: var(--primary-color);
      font-weight: 600;
      margin-bottom: 8px;
    }
    .form-control {
      border-radius: 16px;
      border: 1px solid #d4e7f1;
      padding: 12px 15px;
      background: #f8fcfe;
    }
    .form-control:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem rgba(0, 119, 182, 0.12);
      background: white;
    }
    .password-field {
      position: relative;
    }
    .password-field .form-control {
      padding-right: 48px;
    }
    .password-toggle {
      position: absolute;
      top: 50%;
      right: 14px;
      transform: translateY(-50%);
      border: none;
      background: transparent;
      color: #60717a;
      padding: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      line-height: 1;
    }
    .password-toggle:hover {
      color: var(--secondary-color);
    }
    .password-toggle:focus {
      outline: none;
      color: var(--secondary-color);
    }
    .helper-link {
      color: var(--secondary-color);
      font-weight: 600;
      text-decoration: none;
    }
    .helper-link:hover {
      color: var(--primary-color);
    }
    .btn-primary {
      border: none;
      border-radius: 999px;
      padding: 12px 18px;
      font-weight: 600;
      background: linear-gradient(135deg, var(--secondary-color), #005f89);
      box-shadow: 0 12px 24px var(--card-glow);
    }
    .status-card {
      border-radius: 18px;
      border: 1px solid #d7ebf5;
      background: #f6fbfd;
      padding: 14px 16px;
      margin-bottom: 18px;
    }
    @media (max-width: 991px) {
      .intro-panel {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
      }
    }
    @media (max-width: 767px) {
      .form-panel,
      .intro-panel {
        padding: 28px 22px;
      }
    }
  </style>
</head>
<body class="d-flex justify-content-center align-items-center min-vh-100 py-4">
  <div class="container auth-shell">
    <div class="card auth-card">
      <div class="row g-0">
        <div class="col-lg-5">
          <div class="intro-panel">
            <div class="panel-badge">
              <i class="bi bi-stars"></i>
              Welcome Back
            </div>
            <h2 class="fw-bold mb-3">Sign in and pick up where you left off.</h2>
            <p class="panel-copy mb-0">
              Access your mentorship sessions, feedback, and role-specific dashboard with one account.
            </p>
            <ul class="benefit-list">
              <li><i class="bi bi-check-circle-fill"></i><span>Track mentorship sessions and progress in one place.</span></li>
              <li><i class="bi bi-check-circle-fill"></i><span>Switch back into your role-focused dashboard quickly.</span></li>
              <li><i class="bi bi-check-circle-fill"></i><span>Reset your password anytime if you lose access.</span></li>
            </ul>
          </div>
        </div>
        <div class="col-lg-7">
          <div class="form-panel">
            <div class="text-center mb-4">
              <img src="/images/Logo 1.png" alt="MentorLink Logo" class="brand-mark mb-3">
              <h2 class="section-title">Sign in to MentorLink</h2>
              <p class="section-copy mb-0">Connect, mentor, and grow.</p>
            </div>

            {{#if success}}
            <div class="alert alert-success status-card" role="alert">
              {{success}}
            </div>
            {{/if}}

            <form method="POST" action="/auth/login">
              <div class="mb-3">
                <label for="loginEmail" class="form-label">Email address</label>
                <input type="email" class="form-control" id="loginEmail" name="email" placeholder="Enter your email" required>
              </div>
              <div class="mb-3">
                <label for="loginPassword" class="form-label">Password</label>
                <div class="password-field">
                  <input type="password" class="form-control" id="loginPassword" name="password" placeholder="Enter password" required>
                  <button type="button" class="password-toggle" data-target="loginPassword" aria-label="Show password" aria-pressed="false">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>
              <div class="d-flex justify-content-end mb-4">
                <a href="/auth/forgot-password" class="helper-link small">Forgot password?</a>
              </div>
              <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>

            <div class="small text-center mt-4">
              Don't have an account? <a href="/auth/signup" class="fw-semibold helper-link">Register</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <footer class="mt-4 text-center text-muted small">
      &copy; 2025 MentorLink
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelectorAll('.password-toggle').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const targetInput = document.getElementById(toggle.dataset.target);
        if (!targetInput) return;
        const isVisible = targetInput.type === 'text';
        const icon = toggle.querySelector('i');

        targetInput.type = isVisible ? 'password' : 'text';
        toggle.setAttribute('aria-label', isVisible ? 'Show password' : 'Hide password');
        toggle.setAttribute('aria-pressed', String(!isVisible));

        if (icon) {
          icon.className = isVisible ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
      });
    });
  </script>
</body>
</html>
